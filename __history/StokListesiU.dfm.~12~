  object qStokListesi: TUniQuery
    Connection = frmDM.conNetsis
    SQL.Strings = (
      'SELECT TOP 5'
      'S.STOK_KODU'
      ',S.STOK_ADI'
      '--,ISNULL(SH.DEPO_KODU,'#39#39') AS DEPO_KODU'
      '--,SH.DEPO_KODU'
      
        ',ISNULL(SUM(CASE WHEN SH.DEPO_KODU=3 THEN (CASE WHEN STHAR_GCKOD' +
        '='#39'G'#39' THEN STHAR_GCMIK ELSE -STHAR_GCMIK END) ELSE 0 END), 0) DEP' +
        'O_3'
      
        ',ISNULL(SUM(CASE WHEN SH.DEPO_KODU=100 THEN (CASE WHEN STHAR_GCK' +
        'OD='#39'G'#39' THEN STHAR_GCMIK ELSE -STHAR_GCMIK END) ELSE 0 END), 0) D' +
        'EPO_100'
      
        ',ISNULL(SUM(CASE WHEN SH.DEPO_KODU=200 THEN (CASE WHEN STHAR_GCK' +
        'OD='#39'G'#39' THEN STHAR_GCMIK ELSE -STHAR_GCMIK END) ELSE 0 END), 0) D' +
        'EPO_200'
      ',S.OLCU_BR1'
      ',S.KDV_ORANI'
      ',ISNULL(SF.FIYATDOVIZTIPI,'#39#39') FIYATDOVIZTIPI'
      ',ISNULL(SF.FIYAT1,'#39'0'#39') FIYAT1'
      ',ISNULL(SF.FIYAT2,'#39'0'#39') FIYAT2'
      ',ISNULL(SF.FIYAT3,'#39'0'#39') FIYAT3'
      ',ISNULL(SF.FIYAT4,'#39'0'#39') FIYAT3'
      ',S.DOV_SATIS_FIAT STOK_DOVIZFIYAT'
      ',S.SAT_DOV_TIP'
      ',S.URETICI_KODU'
      ',S.GRUP_KODU'
      ',ISNULL(S.KOD_1,'#39#39') KOD_1'
      ',ISNULL(S.KOD_2,'#39#39') KOD_2'
      ',ISNULL(S.KOD_3,'#39#39') KOD_3'
      ',ISNULL(S.KOD_4,'#39#39') KOD_4'
      ',ISNULL(S.KOD_5,'#39#39') KOD_5'
      'FROM'
      'TBLSTSABIT S WITH(NOLOCK)'
      'LEFT JOIN TBLSTHAR SH WITH(NOLOCK) ON SH.STOK_KODU=S.STOK_KODU'
      
        'OUTER APPLY (SELECT TOP 1 * FROM TBLSTOKFIAT SF WITH(NOLOCK) WHE' +
        'RE SF.STOKKODU=S.STOK_KODU AND SF.FIYATGRUBU='#39'GENEL'#39' ORDER BY BA' +
        'STAR,INCKEYNO DESC) AS SF'
      'WHERE 1=1'
      'GROUP BY'
      'S.STOK_KODU'
      ',S.STOK_ADI'
      ',SF.FIYATDOVIZTIPI'
      ',SF.FIYAT1'
      ',SF.FIYAT2'
      ',SF.FIYAT3'
      ',SF.FIYAT4'
      ',S.OLCU_BR1'
      ',S.KDV_ORANI'
      ',S.URETICI_KODU'
      ',S.GRUP_KODU'
      ',S.DOV_SATIS_FIAT'
      ',S.SAT_DOV_TIP'
      ',S.KOD_1'
      ',S.KOD_2'
      ',S.KOD_3'
      ',S.KOD_4'
      ',S.KOD_5'
      'ORDER BY S.STOK_KODU'
      ''
      ''
      ''
      
        '/* -- 29.12.2023 te de'#287'i'#351'tirilen k'#305's'#305'm buras'#305'd'#305'r. Yedek olarak a' +
        'l'#305'nd'#305'.'
      'SELECT -- TOP 5 '
      
        ' S.SUBE_KODU,S.ISLETME_KODU,S.STOK_KODU,S.URETICI_KODU,S.STOK_AD' +
        'I,S.GRUP_KODU,S.KOD_1,S.KOD_2,S.KOD_3,S.KOD_4,S.KOD_5,S.SATICI_K' +
        'ODU,S.OLCU_BR1,S.OLCU_BR2,S.PAY_1'
      
        ',S.PAYDA_1,S.OLCU_BR3,S.PAY2,S.PAYDA2,S.FIAT_BIRIMI,S.AZAMI_STOK' +
        ',S.ASGARI_STOK,S.TEMIN_SURESI,S.KUL_MIK,S.RISK_SURESI,S.ZAMAN_BI' +
        'RIMI,S.SATIS_FIAT1,S.SATIS_FIAT2,S.SATIS_FIAT3'
      
        ',S.SATIS_FIAT4,S.SAT_DOV_TIP,S.DOV_ALIS_FIAT,S.DOV_MAL_FIAT,S.DO' +
        'V_SATIS_FIAT,S.MUH_DETAYKODU,S.BIRIM_AGIRLIK,S.NAKLIYET_TUT,S.KD' +
        'V_ORANI,S.ALIS_DOV_TIP,S.DEPO_KODU,S.DOV_TUR'
      
        ',S.URET_OLCU_BR,S.BILESENMI,S.MAMULMU,S.FORMUL_TOPLAMI,S.UPDATE_' +
        'KODU,S.MAX_ISKONTO,S.ECZACI_KARI,S.MIKTAR,S.MAL_FAZLASI,S.KDV_TE' +
        'NZIL_ORAN,S.KILIT,S.ONCEKI_KOD,S.SONRAKI_KOD,S.BARKOD1'
      
        ',S.BARKOD2,S.BARKOD3,S.ALIS_KDV_KODU,S.ALIS_FIAT1,S.ALIS_FIAT2,S' +
        '.ALIS_FIAT3,S.ALIS_FIAT4,S.LOT_SIZE,S.MIN_SIP_MIKTAR,S.SABIT_SIP' +
        '_ARALIK,S.SIP_POLITIKASI,S.OZELLIK_KODU1,S.OZELLIK_KODU2'
      
        ',S.OZELLIK_KODU3,S.OZELLIK_KODU4,S.OZELLIK_KODU5,S.OPSIYON_KODU1' +
        ',S.OPSIYON_KODU2,S.OPSIYON_KODU3,S.OPSIYON_KODU4,S.OPSIYON_KODU5' +
        ',S.BILESEN_OP_KODU,S.SIP_VER_MAL,S.ELDE_BUL_MAL'
      
        ',S.YIL_TAH_KUL_MIK,S.EKON_SIP_MIKTAR,S.ESKI_RECETE,S.OTOMATIK_UR' +
        'ETIM,S.ALFKOD,S.SAFKOD,S.KODTURU,S.S_YEDEK1,S.S_YEDEK2,S.F_YEDEK' +
        '3,S.F_YEDEK4,S.C_YEDEK5,S.C_YEDEK6,S.B_YEDEK7'
      
        ',S.I_YEDEK8,S.L_YEDEK9,S.D_YEDEK10,S.GIRIS_SERI,S.CIKIS_SERI,S.S' +
        'ERI_BAK,S.SERI_MIK,S.SERI_GIR_OT,S.SERI_CIK_OT,S.SERI_BASLANGIC,' +
        'S.FIYATKODU,S.FIYATSIRASI,S.PLANLANACAK,S.LOT_SIZECUSTOMER'
      
        ',S.MIN_SIP_MIKTARCUSTOMER,S.GUMRUKTARIFEKODU,S.ABCKODU,S.PERFORM' +
        'ANSKODU,S.SATICISIPKILIT,S.MUSTERISIPKILIT,S.SATINALMAKILIT,S.SA' +
        'TISKILIT,S.EN,S.BOY,S.GENISLIK,S.SIPLIMITVAR'
      
        ',S.SONSTOKKODU,S.ONAYTIPI,S.ONAYNUM,S.FIKTIF_MAM,S.YAPILANDIR,S.' +
        'SBOMVARMI,S.BAGLISTOKKOD,S.YAPKOD,S.ALISTALTEKKILIT,S.SATISTALTE' +
        'KKILIT,S.S_YEDEK3,S.STOKMEVZUAT,S.OTVTEVKIFAT,S.SERIBARKOD'
      
        ',ISNULL((SELECT MIKTAR1_BAKIYE FROM HV_STOK_DEPO_BAKIYE P WITH(N' +
        'OLOCK) WHERE (P.SUBE_KODU = S.SUBE_KODU) AND (P.STOK_KODU = S.ST' +
        'OK_KODU) AND (DEPO_KODU = 3)),0) AS DEPO_3'
      
        ',ISNULL((SELECT MIKTAR1_BAKIYE FROM HV_STOK_DEPO_BAKIYE P WITH(N' +
        'OLOCK) WHERE (P.SUBE_KODU = S.SUBE_KODU) AND (P.STOK_KODU = S.ST' +
        'OK_KODU) AND (DEPO_KODU = 100)),0) AS DEPO_100'
      
        ',ISNULL((SELECT MIKTAR1_BAKIYE FROM HV_STOK_DEPO_BAKIYE P WITH(N' +
        'OLOCK) WHERE (P.SUBE_KODU = S.SUBE_KODU) AND (P.STOK_KODU = S.ST' +
        'OK_KODU) AND (DEPO_KODU = 200)),0) AS DEPO_200'
      ' FROM TBLSTSABIT S'
      
        '-- WHERE ISNULL((SELECT MIKTAR1_BAKIYE FROM HV_STOK_DEPO_BAKIYE ' +
        'P WITH(NOLOCK) WHERE (P.SUBE_KODU = S.SUBE_KODU) AND (P.STOK_KOD' +
        'U = S.STOK_KODU) AND (DEPO_KODU = 3)),0) > 0'
      '*/ ')
    Left = 920
    Top = 464
  end
