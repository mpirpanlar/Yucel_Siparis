procedure TfrmStokListesi.btnListeleClick(Sender: TObject);
Var
CariAdi :String;
SL: TStringList;
i:integer;

begin

  qStokListesi.Close;
  qStokListesi.SQL.Clear;
  SQL:=' SELECT S.SUBE_KODU,S.ISLETME_KODU,S.STOK_KODU,S.URETICI_KODU,S.STOK_ADI,S.GRUP_KODU,S.KOD_1,S.KOD_2,S.KOD_3,S.KOD_4,S.KOD_5,S.SATICI_KODU,S.OLCU_BR1,S.OLCU_BR2,S.PAY_1 '
        +' ,S.PAYDA_1,S.OLCU_BR3,S.PAY2,S.PAYDA2,S.FIAT_BIRIMI,S.AZAMI_STOK,S.ASGARI_STOK,S.TEMIN_SURESI,S.KUL_MIK,S.RISK_SURESI,S.ZAMAN_BIRIMI,S.SATIS_FIAT1,S.SATIS_FIAT2,S.SATIS_FIAT3 '
        +' ,S.SATIS_FIAT4,S.SAT_DOV_TIP,S.DOV_ALIS_FIAT,S.DOV_MAL_FIAT,S.DOV_SATIS_FIAT,S.MUH_DETAYKODU,S.BIRIM_AGIRLIK,S.NAKLIYET_TUT,S.KDV_ORANI,S.ALIS_DOV_TIP,S.DEPO_KODU,S.DOV_TUR '
        +' ,S.URET_OLCU_BR,S.BILESENMI,S.MAMULMU,S.FORMUL_TOPLAMI,S.UPDATE_KODU,S.MAX_ISKONTO,S.ECZACI_KARI,S.MIKTAR,S.MAL_FAZLASI,S.KDV_TENZIL_ORAN,S.KILIT,S.ONCEKI_KOD,S.SONRAKI_KOD,S.BARKOD1 '
        +' ,S.BARKOD2,S.BARKOD3,S.ALIS_KDV_KODU,S.ALIS_FIAT1,S.ALIS_FIAT2,S.ALIS_FIAT3,S.ALIS_FIAT4,S.LOT_SIZE,S.MIN_SIP_MIKTAR,S.SABIT_SIP_ARALIK,S.SIP_POLITIKASI,S.OZELLIK_KODU1,S.OZELLIK_KODU2 '
        +' ,S.OZELLIK_KODU3,S.OZELLIK_KODU4,S.OZELLIK_KODU5,S.OPSIYON_KODU1,S.OPSIYON_KODU2,S.OPSIYON_KODU3,S.OPSIYON_KODU4,S.OPSIYON_KODU5,S.BILESEN_OP_KODU,S.SIP_VER_MAL,S.ELDE_BUL_MAL '
        +' ,S.YIL_TAH_KUL_MIK,S.EKON_SIP_MIKTAR,S.ESKI_RECETE,S.OTOMATIK_URETIM,S.ALFKOD,S.SAFKOD,S.KODTURU,S.S_YEDEK1,S.S_YEDEK2,S.F_YEDEK3,S.F_YEDEK4,S.C_YEDEK5,S.C_YEDEK6,S.B_YEDEK7 '
        +' ,S.I_YEDEK8,S.L_YEDEK9,S.D_YEDEK10,S.GIRIS_SERI,S.CIKIS_SERI,S.SERI_BAK,S.SERI_MIK,S.SERI_GIR_OT,S.SERI_CIK_OT,S.SERI_BASLANGIC,S.FIYATKODU,S.FIYATSIRASI,S.PLANLANACAK,S.LOT_SIZECUSTOMER '
        +' ,S.MIN_SIP_MIKTARCUSTOMER,S.GUMRUKTARIFEKODU,S.ABCKODU,S.PERFORMANSKODU,S.SATICISIPKILIT,S.MUSTERISIPKILIT,S.SATINALMAKILIT,S.SATISKILIT,S.EN,S.BOY,S.GENISLIK,S.SIPLIMITVAR '
        +' ,S.SONSTOKKODU,S.ONAYTIPI,S.ONAYNUM,S.FIKTIF_MAM,S.YAPILANDIR,S.SBOMVARMI,S.BAGLISTOKKOD,S.YAPKOD,S.ALISTALTEKKILIT,S.SATISTALTEKKILIT,S.S_YEDEK3,S.STOKMEVZUAT,S.OTVTEVKIFAT,S.SERIBARKOD '
        +' ,ISNULL((SELECT MIKTAR1_BAKIYE FROM HV_STOK_DEPO_BAKIYE P WITH(NOLOCK) WHERE (P.SUBE_KODU = '''+ IntToStr(Tmp.xSubeKodu) +''') AND (P.STOK_KODU = S.STOK_KODU) AND (DEPO_KODU = 3)),0) AS DEPO_3 '
        +' ,ISNULL((SELECT MIKTAR1_BAKIYE FROM HV_STOK_DEPO_BAKIYE P WITH(NOLOCK) WHERE (P.SUBE_KODU = '''+ IntToStr(Tmp.xSubeKodu) +''') AND (P.STOK_KODU = S.STOK_KODU) AND (DEPO_KODU = 100)),0) AS DEPO_100 '
        +' ,ISNULL((SELECT MIKTAR1_BAKIYE FROM HV_STOK_DEPO_BAKIYE P WITH(NOLOCK) WHERE (P.SUBE_KODU = '''+ IntToStr(Tmp.xSubeKodu) +''') AND (P.STOK_KODU = S.STOK_KODU) AND (DEPO_KODU = 200)),0) AS DEPO_200 '
        +' FROM TBLSTSABIT S where S.STOK_KODU = S.STOK_KODU ';
  SL := TStringList.Create;
  SL.Delimiter := ' ';//Boţluk
  SL.DelimitedText := edCariKod.Text;

//  SQL:= SQL+' and ((S.SUBE_KODU = '''+ IntToStr(xSubeKodu) +''')) ';

      if edCariKod.Text <> '' then begin
        for i:=0 to SL.Count-1 do begin
          CariAdi:=SL.Strings[i];
          SQL:= SQL+' and ((S.STOK_KODU like''%'+CariAdi+'%'') OR (DBO.TRK(S.STOK_ADI) like''%'+CariAdi+'%'')) ';
        end;
   end;

//   if cbFaturaDurum.ItemIndex = 1 then
//    SQL:= SQL+' and (NetsisSiparisNo Is Not Null OR NetsisSiparisNo <> '' '') ';
//   if cbFaturaDurum.ItemIndex = 2 then
//    SQL:= SQL+' and (NetsisSiparisNo Is Null OR NetsisSiparisNo = '' '') ';


  qStokListesi.SQL.Text:=SQL;
  qStokListesi.Open;
  SL.Free;

end;

