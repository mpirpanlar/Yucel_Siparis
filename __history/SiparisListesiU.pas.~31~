end;

procedure TfrmSiparisListesi.btnListeleClick(Sender: TObject);
Var
CariAdi :String;
SL: TStringList;
i:integer;

begin

  qSiparisListesi.Close;
  qSiparisListesi.SQL.Clear;
  SQL:='SELECT B.* '
        +' , C.CARI_ISIM, K.KullaniciAd '
        +' FROM SIPARIS_BASLIK B '
        +'	LEFT JOIN ' + Tmp.xNetsisSirketKodu + '.DBO.TBLCASABIT C WITH(NOLOCK) ON (C.CARI_KOD = B.CariKod) '
        +'	LEFT JOIN KULLANICI K ON (K.KullaniciID = B.PersonelKodu) '
        +' where Tarih between :Tarih1 and :Tarih2 ';

        if Tmp.xKullaniciAdmin <> 1 then
          begin
//            SQL := SQL + ' and KayitKullanici =:Kul ';
            SQL := SQL + ' and KayitKullanici = '''+IntToStr(Tmp.xKullaniciID)+'''  ';
          end;



  SL := TStringList.Create;
  SL.Delimiter := ' ';//Boţluk
  SL.DelimitedText := edCariKod.Text;

   if edCariKod.Text <> '' then begin
        for i:=0 to SL.Count-1 do begin
          CariAdi:=SL.Strings[i];
          SQL:= SQL+' and ((B.CariKod like''%'+CariAdi+'%'') or (C.CARI_ISIM like''%'+CariAdi+'%'') or (FisNo like''%'+CariAdi+'%'')) ';
        end;
   end;

   if cbFaturaDurum.ItemIndex = 1 then
    SQL:= SQL+' and (NetsisSiparisNo Is Not Null OR NetsisSiparisNo <> '' '') ';
   if cbFaturaDurum.ItemIndex = 2 then
    SQL:= SQL+' and (NetsisSiparisNo Is Null OR NetsisSiparisNo = '' '') ';


  qSiparisListesi.SQL.Text:=SQL;
  qSiparisListesi.ParamByName('Tarih1').Value:=UniDateTimePicker1.DateTime;
  qSiparisListesi.ParamByName('Tarih2').Value:=UniDateTimePicker2.DateTime;
//  if xKullaniciAdmin <> 1 then
//    begin
//      qSiparisListesi.ParamByName('Kul').Value:=xKullaniciAdmin;
//    end;
  qSiparisListesi.Open;
  SL.Free;

  btnGuncelle.Enabled := True;

end;

procedure TfrmSiparisListesi.btnGuncelleClick(Sender: TObject);
begin
  if qSiparisListesi.FieldByName('NetsisSiparisNo').AsString <> '' then
    begin
      UniMainModule.saHata.Show('Netsis e gönderilen sipariţ güncellenemez.');
      Abort;
    end;

  xFormShow(TfrmSiparis,'SatisSiparisi',1,qSiparisListesi.FieldByName('FisNo').AsString);
end;

