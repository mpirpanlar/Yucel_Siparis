    q.SQL.Clear;
    q.SQL.Add(' SELECT TOP 1 GUID FROM TBLCARISKLOG WHERE CARIKOD =:Cari ORDER BY ISLEMTARIHI DESC');
    q.ParamByName('Cari').AsString := qCariListesi.FieldByName('CARI_KOD').AsString;
