  object qCariListesi: TUniQuery
    Connection = frmDM.conNetsis
    SQL.Strings = (
      
        'SELECT TOP 5 C.CARI_KOD, C.CARI_ISIM, C.CARI_IL, C.CARI_ILCE, R.' +
        'RISKLIMITI'
      
        ',CASE WHEN C.C_YEDEK1 = '#39'B'#39' THEN '#39'KILITLI'#39' WHEN C.C_YEDEK1 = '#39'A'#39 +
        ' THEN '#39'ACIK'#39' END '#39'KILIT_DURUM'#39
      #9'FROM TBLCASABIT C'
      #9#9'LEFT JOIN TBLCARISK R WITH(NOLOCK) ON R.CARIKOD = C.CARI_KOD')
