procedure TfrmSiparis.UniDBGrid2ColumnSummary(Column: TUniDBGridColumn;
  GroupFieldValue: Variant);
begin
  if SameText(Column.FieldName, 'BrutToplam') then
  begin
    if Column.AuxValue=NULL then Column.AuxValue:=0;
    Column.AuxValue:=Column.AuxValue + Column.Field.AsFloat;
  end
  else
  if SameText(Column.FieldName, 'cIskToplam') then
  begin
    if Column.AuxValue=NULL then Column.AuxValue:=0;
    Column.AuxValue:=Column.AuxValue + Column.Field.AsFloat;
  end
  else
  if SameText(Column.FieldName, 'cNetToplam') then
  begin
    if Column.AuxValue=NULL then Column.AuxValue:=0;
    Column.AuxValue:=Column.AuxValue + Column.Field.AsFloat;
  end
  else
  if SameText(Column.FieldName, 'cKdvTutar') then
  begin
    if Column.AuxValue=NULL then Column.AuxValue:=0;
    Column.AuxValue:=Column.AuxValue + Column.Field.AsFloat;
  end
  else
  if SameText(Column.FieldName, 'Kdv') then
  begin
    if Column.AuxValue=NULL then Column.AuxValue:=0;
    Column.AuxValue:=Column.AuxValue + Column.Field.AsFloat;
  end
end;

procedure TfrmSiparis.UniDBGrid2ColumnSummaryResult(Column: TUniDBGridColumn;
  GroupFieldValue: Variant; Attribs: TUniCellAttribs; var Result: string);
Var
  BrutToplam, IskToplam, NetToplam, KdvTutar, Kdv : Real;
begin

  if frmSiparisDM.qFisBaslik.State IN [dsBrowse] then frmSiparisDM.qFisBaslik.Edit;
  if SameText(Column.FieldName, 'BrutToplam') then
  begin
    BrutToplam:=Column.AuxValue;
    Result:=FormatCurr('0,0.00 ', BrutToplam);
    Attribs.Font.Style:=[fsBold];
