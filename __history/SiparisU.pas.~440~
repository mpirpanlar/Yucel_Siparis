procedure TfrmSiparis.btnKurGuncelleClick(Sender: TObject);
var
  StokParaBirimi : String;
  Kur : Real;
begin
  KurOku();
  if frmSiparisDM.qFisDetay.RecordCount > 0 then
    begin
      frmSiparisDM.qFisDetay.First;
      while not frmSiparisDM.qFisDetay.Eof do
        begin

          StokParaBirimi := frmSiparisDM.qFisDetay.FieldByName('ParaBirimi').AsString;

          if frmSiparisDM.qDoviz.Locate('SIRA',StokParabirimi,[]) = True then
            begin

              if Tmp.xDovizTakip = 1 then
                begin
                  Kur := frmSiparisDM.qDoviz.FieldByName('DOV_SATIS').AsFloat;
                end else if tmp.xDovizTakip = 2 then
                         begin
                            Kur := frmSiparisDM.qDoviz.FieldByName('EFF_SATIS').AsFloat;
                         end;

            end else
            begin
              Kur := 1;
            end;

          frmSiparisDM.qFisDetay.Edit;
          frmSiparisDM.qFisDetay.FieldByName('SatisKur').AsFloat := Kur;
          frmSiparisDM.qFisDetayCalcFields(frmSiparisDM.qFisDetay);
          frmSiparisDM.qFisDetay.Post;

          frmSiparisDM.qFisDetay.Next;
        end;

    end;

end;

