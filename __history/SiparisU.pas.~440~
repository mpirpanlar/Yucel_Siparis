procedure TfrmSiparis.UniDBEdit2ChangeValue(Sender: TObject);
begin
  if frmSiparisDM.qFisDetay.State IN[dsEdit,dsInsert] then
    begin
      if frmSiparisDM.qDoviz.Locate('SIRA',Trim(UniDBEdit2.Text),[]) = True then
        begin

          if Tmp.xDovizTakip = 1 then
            begin
              frmSiparisDM.qFisDetay.FieldByName('SatisKur').AsFloat := frmSiparisDM.qDoviz.FieldByName('DOV_SATIS').AsFloat;
            end else if tmp.xDovizTakip = 2 then
                     begin
                      frmSiparisDM.qFisDetay.FieldByName('SatisKur').AsFloat := frmSiparisDM.qDoviz.FieldByName('EFF_SATIS').AsFloat;
                     end;


          frmSiparisDM.qFisDetay.FieldByName('DovizAdi').AsString := frmSiparisDM.qDoviz.FieldByName('ISIM').AsString;
        end else
        begin
          frmSiparisDM.qFisDetay.FieldByName('SatisKur').AsFloat := 1;
        end;
    end;
end;

