procedure TfrmSiparis.NetsisMusteriSiparisi();
Var
  Kernel : IKernel;
  Sirket : ISirket;
  Siparis : IFatura;
  SipUst : IFatUst;
  SipKalem : IFatKalem;
  q:TUniQuery;
  NetsisSipNo : String;
Begin

  try

//    NetsisBaglan;

//    Kullanici:='NETSIS';
//    Sifre:='net1';
//    Firma:='TESTBOSSIRKET';
//    Sube := 0;

    Kullanici:= Tmp.xNetsisKullanici;
    Sifre:=Tmp.xNetsisSifre;
    Firma:=Tmp.xNetsisSirketKodu;
    Sube := Tmp.xSubeKodu;

    if Kernel = nil then
      begin
        try
          Kernel:=CoKernel.Create;
          Sirket := Kernel.yeniSirket(vtMSSQL, Firma, 'TemelSet', '', Kullanici, Sifre, Sube);
//          Sirket := Kernel.yeniSirket(vtMSSQL, 'YUCELTEST', 'TemelSet', '', 'NETSIS', 'net1', 0);

        except
          On E:Exception do
            begin
              Screen.Cursor := crDefault;
              UniMainModule.saKaydet.Show('Bađlantý Hatasý -> ' + E.Message);
              Abort;
            end;
        end;
      end;

      try
        q := TUniQuery.Create(Self);
        q.Connection:= frmDM.conNetsis;
        q.Close;
        q.SQL.Clear;
//        q.SQL.Add('SELECT FISNO =''M2023''+RIGHT(''0000000000''+CONVERT(VARCHAR,((SELECT (MAX(SUBSTRING(FATIRS_NO,6,10))+1) FROM TBLSIPAMAS WHERE SUBE_KODU = 0 AND FTIRSIP = ''6'' AND FATIRS_NO LIKE ''M2023%''))),10) ');
//        q.SQL.Add('SELECT FISNO =''M2024''+RIGHT(''0000000000''+CONVERT(VARCHAR,((SELECT (MAX(SUBSTRING(FATIRS_NO,6,10))+1) FROM TBLSIPAMAS WHERE FTIRSIP = ''6'' AND FATIRS_NO LIKE ''M2024%''))),10) ');
        q.SQL.Add('SELECT FISNO = DBO.FISNOVER(' + IntToStr(YearOf(now)) + ')');     // 2024-01-01 de eklendi.
        q.ExecSQL;
        NetsisSipNo := q.FieldByName('FISNO').AsString;
        q.Close;
        FreeAndNil(q);
      except
        On E:Exception do
          begin
            Screen.Cursor := crDefault;
            UniMainModule.saKaydet.Show('Netsis Sipariţ No alýnamadý ! ' + E.Message);
            Abort;
          end;
      end;



    Siparis := Kernel.yeniFatura(Sirket,ftSSip);
    //Siparis Ust Bilgilerini Olustur
    SipUst := Siparis.Ust;
    SipUst.FATIRS_NO := NetsisSipNo;
    SipUst.TIPI := ft_Acik;
    SipUst.CariKod := frmSiparisDM.qFisBaslik.FieldByName('CariKod').AsString;
    SipUst.TARIH := frmSiparisDM.qFisBaslik.FieldByName('Tarih').AsDateTime;
    SipUst.SIPARIS_TEST := frmSiparisDM.qFisBaslik.FieldByName('SevkTarihi').AsDateTime;
    SipUst.DovBazTarihi := frmSiparisDM.qFisBaslik.FieldByName('DovizTarih').AsDateTime;
    SipUst.FIYATTARIHI := frmSiparisDM.qFisBaslik.FieldByName('Tarih').AsDateTime;
    SipUst.PLA_KODU := Tmp.xNetsisPlasiyer;
    SipUst.KOD1 := frmSiparisDM.qFisBaslik.FieldByName('OzelKod').AsString;
    SipUst.KOD2 := frmSiparisDM.qFisBaslik.FieldByName('OzelKod2').AsString;
    SipUst.Proje_Kodu := frmSiparisDM.qFisBaslik.FieldByName('ProjeKodu').AsString;
    SipUst.Aciklama := frmSiparisDM.qFisBaslik.FieldByName('Aciklama').AsString;
    SipUst.ODEMEGUNU := frmSiparisDM.qFisBaslik.FieldByName('VadeGunu').AsInteger;

