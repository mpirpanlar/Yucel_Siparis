function TfrmSiparis.FisNoGetir:String;
var
  UretimNo : String;
  q1 : TUniQuery;
begin

  q1 := TUniQuery.Create(nil);
  q1.Connection := frmDM.conAsya;

  with q1 do
    begin
      Application.ProcessMessages;
      Close;
      SQL.Clear;
//      SQL.Add('Select dbo.NumaraSeriAl(''YUKLEMENO'',''YUK'') as YuklemeNo');
      SQL.Add(' Select dbo.NumaraSeriAl2(''TEKLIF'',''T'') as YuklemeNo ');
      Open;
      Application.ProcessMessages;
      UretimNo := FieldByName('YuklemeNo').AsString;

      Close;
      SQL.Clear;
      SQL.Add('Update NumaraSerileri Set SonrakiSayi = SonrakiSayi+1 Where Formati = ''T''');
      ExecSQL;
      Close;
      FreeAndNil(q1);

      Result := UretimNo;
    end;

end;


