unit SiparisSatirGuncelleU;

interface

uses
  Windows, Messages, SysUtils, Variants, Classes, Graphics,
  Controls, Forms, uniGUITypes, uniGUIAbstractClasses,
  uniGUIClasses, uniGUIForm, uniEdit, uniButton, uniGUIBaseClasses, uniPanel,
  uniLabel, Data.DB,  DBAccess, uniDBComboBox, uniDBLookupComboBox,
  uniMultiItem, uniComboBox, MemDS, Uni, System.Math;

type
  TfrmSiparisSatirGuncelle = class(TUniForm)
    UniPanel1: TUniPanel;
    btnAktar: TUniButton;
    txtMiktar: TUniFormattedNumberEdit;
    txtBirimFiyat: TUniFormattedNumberEdit;
    lblStokKodu: TUniLabel;
    txtDovizFiyat: TUniFormattedNumberEdit;
    txtKur: TUniFormattedNumberEdit;
    txtTLFiyat: TUniFormattedNumberEdit;
    dovizCombo: TUniDBLookupComboBox;
    UniQuery1: TUniQuery;
    lblBirim: TUniLabel;
    procedure btnAktarClick(Sender: TObject);
    procedure UniFormShow(Sender: TObject);
    procedure txtBirimFiyatKeyPress(Sender: TObject; var Key: Char);
    procedure txtMiktarClick(Sender: TObject);
    procedure txtBirimFiyatClick(Sender: TObject);
  private
    { Private declarations }
  public
    { Public declarations }
    FisDetayID, DovizSira : Integer;
    StokKodu, Birim : String;
    DovizFiyat, Kur, TLFiyat, Miktar :Real;
  end;

function frmSiparisSatirGuncelle: TfrmSiparisSatirGuncelle;

implementation

{$R *.dfm}

uses
  MainModule, uniGUIApplication, SiparisDMU, DMU;

function frmSiparisSatirGuncelle: TfrmSiparisSatirGuncelle;
begin
  Result := TfrmSiparisSatirGuncelle(UniMainModule.GetFormInstance(TfrmSiparisSatirGuncelle));
end;

procedure TfrmSiparisSatirGuncelle.btnAktarClick(Sender: TObject);
var
  q:TUniQuery;
  Birim, Birim2 : String;
  GirilenMiktar, Miktar2:Real;
  Cevrim : Integer;
begin

  q := TUniQuery.Create(Self);
  q.Connection := frmDM.conNetsis;

  q.Close;
  q.SQL.Clear;
  q.SQL.Add('SELECT STOK_KODU, STOK_ADI, BARKOD1, BARKOD2, BARKOD3, OLCU_BR1, PAY_1, PAYDA_1, OLCU_BR2, PAY2, PAYDA2, OLCU_BR3  FROM TBLSTSABIT WHERE STOK_KODU =:Stk');
  q.ParamByName('Stk').AsString := StokKodu;;
  q.Open;

  GirilenMiktar := txtMiktar.Value;

  if Birim=q.FieldByName('OLCU_BR1').AsString then begin
    Miktar:=GirilenMiktar;
    Cevrim := 0;
    Miktar2 := RoundTo((GirilenMiktar * ((q.FieldByName('PAY_1').AsFloat / q.FieldByName('PAYDA_1').AsFloat))),-4);
    Birim2 := q.FieldByName('OLCU_BR2').AsString;
  end;



  frmSiparisDM.qFisDetay.Edit;
    frmSiparisDM.qFisDetay.FieldByName('Miktar').AsFloat := txtMiktar.Value;
    frmSiparisDM.qFisDetay.FieldByName('BirimFiyat').AsFloat := txtBirimFiyat.Value;
    frmSiparisDM.qFisDetay.FieldByName('ParaBirimi').AsString := IntToStr(dovizCombo.KeyValue);
    frmSiparisDM.qFisDetay.FieldByName('DovizAdi').AsString := Trim(dovizCombo.Text);

    frmSiparisDM.qFisDetay.FieldByName('StokGercekBirim').AsString := Birim2;
    frmSiparisDM.qFisDetay.FieldByName('GercekMiktar').AsFloat := Miktar2;


  frmSiparisDM.qFisDetay.Post;

  if frmSiparisDM.qFisBaslik.State IN [dsEdit,dsInsert] then frmSiparisDM.qFisBaslik.Post;

  if frmSiparisDM.qFisDetay.State IN [dsEdit,dsInsert] then frmSiparisDM.qFisDetay.Post;
      frmSiparisDM.qFisDetay.ApplyUpdates;

  if frmSiparisDM.qEk.State IN [dsEdit,dsInsert] then frmSiparisDM.qEk.Post;
      frmSiparisDM.qEk.ApplyUpdates;

  Close;

end;

procedure TfrmSiparisSatirGuncelle.txtBirimFiyatClick(Sender: TObject);
begin
  txtBirimFiyat.SelectAll;
end;

procedure TfrmSiparisSatirGuncelle.txtBirimFiyatKeyPress(Sender: TObject;
  var Key: Char);
begin
  if Key = #13 then
    begin
      btnAktar.Click;
    end;

end;

procedure TfrmSiparisSatirGuncelle.txtMiktarClick(Sender: TObject);
begin
  txtMiktar.SelectAll;
end;

procedure TfrmSiparisSatirGuncelle.UniFormShow(Sender: TObject);
begin
  lblStokKodu.Caption := StokKodu;
  txtDovizFiyat.Value := DovizFiyat;
  txtBirimFiyat.Value := DovizFiyat;
  txtKur.Value := Kur;
  lblBirim.Caption := Birim;
  txtTLFiyat.Value := TLFiyat;
  dovizCombo.KeyValue := DovizSira;


  txtMiktar.Value := Miktar;
  txtMiktar.SetFocus;
  txtMiktar.SelectAll;
end;

end.
