  object qSiparis: TUniQuery
    Connection = frmDM.conNetsis
    SQL.Strings = (
      'SELECT '
      'FISNO '
      ',S.STHAR_TARIH '
      ',S.STOK_KODU, ST.STOK_ADI '
      ',S.STHAR_GCMIK '
      ',S.STHAR_GCMIK2 '
      ',S.STHAR_GCMIK AS MIKTAR1 '
      ',ST.OLCU_BR1 '
      ',S.STHAR_GCMIK * (ST.PAY_1/ST.PAYDA_1) AS MIKTAR2 '
      ',ST.OLCU_BR2 '
      ',S.STHAR_GCMIK * (ST.PAY2/ST.PAYDA2) AS MIKTAR3 '
      ',ST.OLCU_BR3 '
