  object qStokCariDetay: TUniQuery
    Connection = frmDM.conNetsis
    SQL.Strings = (
      ''
      
        'SELECT H.STOK_KODU, S.STOK_ADI, H.FISNO, H.STHAR_TARIH AS TARIH,' +
        ' H.STHAR_ACIKLAMA AS CARI_KOD, C.CARI_ISIM, H.DEPO_KODU'
      
        ', H.STHAR_GCMIK AS MIKTAR, H.STHAR_DOVTIP AS DOV_TIP, CASE WHEN ' +
        'H.STHAR_DOVTIP = 0 THEN '#39'TL'#39' ELSE D.ISIM END '#39'DOVIZ'#39', H.STHAR_DO' +
        'VFIAT AS DOV_FIAT, H.STHAR_NF AS NET_FIAT, STHAR_KDV AS KDV'
      ',H.STHAR_SIPNUM AS SIPARISNO'
      ',SB.OzelKod5 AS '#39'KOSUL_KODU'#39', KOS.ACIKLAMA AS '#39'KOSUL_ACIKLAMA'#39
      ', ISNULL(SD.IskYuzde_1,0) AS ISK_ORANI'
      ''
      'FROM TBLSTHAR H'
      
        #9'INNER JOIN TBLSTSABIT S WITH(NOLOCK) ON (S.STOK_KODU = H.STOK_K' +
        'ODU)'
      
        #9'INNER JOIN TBLCASABIT C WITH(NOLOCK) ON (C.CARI_KOD = H.STHAR_A' +
        'CIKLAMA)'
      
        #9'INNER JOIN NETSIS.DBO.KUR D WITH(NOLOCK) ON (D.SIRA = H.STHAR_D' +
        'OVTIP)'
      
        'LEFT JOIN ASYA_ENTEGRE..SIPARIS_BASLIK SB WITH(NOLOCK) ON SB.Net' +
        'sisSiparisNo=H.STHAR_SIPNUM'
      
        'LEFT JOIN ASYA_ENTEGRE..SIPARIS_DETAY SD WITH(NOLOCK) ON (SD.Fis' +
        'No = SB.FisNo) AND (SD.StokKod = H.STOK_KODU)'
      
        'LEFT JOIN TBLKOSULMAS KOS WITH(NOLOCK) ON (KOS.KOSUL_KOD = SB.Oz' +
        'elKod5)'
      ''
      'WHERE H.STOK_KODU = '#39'201001-003'#39
      'AND H.STHAR_ACIKLAMA = '#39'000000'#39
      'AND H.STHAR_FTIRSIP = '#39'1'#39
      'AND H.DEPO_KODU = 3'
      ''
      ''
      ''
      ''
      '')
    ReadOnly = True
    Left = 488
    Top = 304
  end
