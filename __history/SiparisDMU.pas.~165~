procedure TfrmSiparisDM.StokEkle(GelenStok : String; Birim : String; GelenMiktar : Real; Doviz:String; Ozel1,Ozel2:SmallInt;SatirEK1,SatirEK2:String);
var
  q:TUniQuery;
  SatisFiyat, DovizFiyat, Cevrim, Miktar, Miktar2 :Real;
  DovizTipi : Integer;
  StokKod, StokAd, Birim2, GlnDoviz : String;
begin

  GlnDoviz := Doviz;
  q := TUniQuery.Create(Self);
  q.Connection := frmDM.conNetsis;

  q.Close;
  q.SQL.Clear;
  q.SQL.Add('SELECT STOK_KODU, STOK_ADI, BARKOD1, BARKOD2, BARKOD3, OLCU_BR1, PAY_1, PAYDA_1, OLCU_BR2, PAY2, PAYDA2, OLCU_BR3  FROM TBLSTSABIT WHERE STOK_KODU =:Stk');
  q.ParamByName('Stk').AsString := GelenStok;
  q.Open;

  StokKod := q.FieldByName('STOK_KODU').AsString;
  StokAd := q.FieldByName('STOK_ADI').AsString;

  if Birim=q.FieldByName('OLCU_BR1').AsString then begin
    Miktar:=GelenMiktar;
    Cevrim := 0;
    Miktar2 := RoundTo((GelenMiktar * ((q.FieldByName('PAY_1').AsFloat / q.FieldByName('PAYDA_1').AsFloat))),-4);
    Birim2 := q.FieldByName('OLCU_BR2').AsString;
  end;

  if Birim=q.FieldByName('OLCU_BR2').AsString then begin
    Miktar:=GelenMiktar * ((q.FieldByName('PAY_1').AsFloat * q.FieldByName('PAYDA_1').AsFloat));
    Cevrim := (q.FieldByName('PAY_1').AsFloat * q.FieldByName('PAYDA_1').AsFloat);
    Miktar2 := GelenMiktar;
    Birim2 := q.FieldByName('OLCU_BR2').AsString;
    Birim := q.FieldByName('OLCU_BR1').AsString; // Gelen birim 2.Birimdi. Ancak satýr a giderken birinci birim olarak gitmeli.
  end;

  if Birim=q.FieldByName('OLCU_BR3').AsString then
  begin
    Miktar:=GelenMiktar * ((q.FieldByName('PAY2').AsFloat * q.FieldByName('PAYDA2').AsFloat));
    Cevrim := (q.FieldByName('PAY2').AsFloat * q.FieldByName('PAYDA2').AsFloat);
    Miktar2 := GelenMiktar;
    Birim2 := q.FieldByName('OLCU_BR3').AsString;
    Birim := q.FieldByName('OLCU_BR1').AsString; // Gelen birim 2.Birimdi. Ancak satýr a giderken birinci birim olarak gitmeli.
  end;

  q.Close;
  FreeAndNil(q);

  frmSiparisDM.SiparisSatirEkle(StokKod,Miktar,Cevrim,Birim,Miktar2,Birim2,GlnDoviz,Ozel1,Ozel2,SatirEK1,SatirEK2);


end;


