procedure TfrmSiparisDM.qFisDetayCalcFields(DataSet: TDataSet);
  Var
    IskToplam :Double;
    EskiBirimFiyat, YeniBirimFiyat, EskiNetBirimFiyat, YeniNetBirimFiyat, BrutToplam, NetToplam, CariBirimFiyat : Real;
    _BrutToplam, _IskToplam, _NetToplam : Real;
begin

              // Cari Birim Fiyat belirleme
      if qFisDetay.FieldByName('CariKur').AsFloat > 0 then begin
          qFisDetay.FieldByName('cCariBirimFiyat').AsFloat :=
            RoundTo(((qFisDetay.FieldByName('SatisKur').AsFloat * qFisDetay.FieldByName('BirimFiyat').AsFloat) /
              qFisDetay.FieldByName('CariKur').AsFloat),-2);
        end else
        begin
          qFisDetay.FieldByName('cCariBirimFiyat').AsFloat :=
            RoundTo((qFisDetay.FieldByName('SatisKur').AsFloat * qFisDetay.FieldByName('BirimFiyat').AsFloat),-2);
        end;



      CariBirimFiyat := qFisDetay.FieldByName('cCariBirimFiyat').AsFloat;

//      _BrutToplam := xYuvarla((qFisDetay.FieldByName('Miktar').AsFloat * qFisDetay.FieldByName('cCariBirimFiyat').AsFloat),5); //--- burayý 2 den 4 e aldým
      BrutToplam := xYuvarla((qFisDetay.FieldByName('Miktar').AsFloat * qFisDetay.FieldByName('cCariBirimFiyat').AsFloat),5); //

//      _IskToplam :=  ((_BrutToplam * qFisDetay.FieldByName('IskYuzde_1').AsFloat) / 100) ;
//      _IskToplam :=  (((_BrutToplam * qFisDetay.FieldByName('IskYuzde_3').AsFloat) / 100) + IskToplam);
//      _IskToplam := xYuvarla((iskToplam + qFisDetay.FieldByName('IskTutar').AsFloat),5);

      IskToplam :=  ((BrutToplam * qFisDetay.FieldByName('IskYuzde_1').AsFloat) / 100) ;
      IskToplam :=  (((BrutToplam * qFisDetay.FieldByName('IskYuzde_3').AsFloat) / 100) + IskToplam);
      IskToplam := xYuvarla((iskToplam + qFisDetay.FieldByName('IskTutar').AsFloat),5);

      qFisDetay.FieldByName('cIskToplam').AsFloat := IskToplam;

//      _NetToplam := (_BrutToplam - _IskToplam);
      NetToplam := (BrutToplam - IskToplam);

      qFisDetay.FieldByName('cIskTutar1').AsFloat := IskToplam;

//      qFisDetay.FieldByName('cKdvTutar').AsFloat:= (NetToplam * qFisDetay.FieldByName('Kdv').AsFloat / 100 ) ;  // 06.10.2022 - Musanýn talebii ile test ediliyor.
      qFisDetay.FieldByName('cKdvTutar').AsFloat:= RoundTo((NetToplam * qFisDetay.FieldByName('Kdv').AsFloat / 100 ),-2) ;

      if qFisDetay.FieldByName('Miktar').AsFloat > 0 then
        begin
          if qFisDetay.FieldByName('GercekMiktar').IsNull then
            begin
              qFisDetay.FieldByName('cNetBirimFiyat').AsFloat := NetToplam / qFisDetay.FieldByName('Miktar').AsFloat;
//              qFisDetay.FieldByName('cNetBirimFiyat').AsFloat := _NetToplam / qFisDetay.FieldByName('Miktar').AsFloat;
            end else
            begin
              qFisDetay.FieldByName('cNetBirimFiyat').AsFloat := NetToplam / qFisDetay.FieldByName('Miktar').AsFloat;
    //          qFisDetay.FieldByName('cNetBirimFiyat').AsFloat := NetToplam / qFisDetay.FieldByName('GercekMiktar').AsFloat;
              qFisDetay.FieldByName('cKdvBirimFiyat').AsFloat := (qFisDetay.FieldByName('cKdvTutar').AsFloat / qFisDetay.FieldByName('Miktar').AsFloat) + NetToplam;

//              qFisDetay.FieldByName('cNetBirimFiyat').AsFloat := _NetToplam / qFisDetay.FieldByName('Miktar').AsFloat;
//    //          qFisDetay.FieldByName('cNetBirimFiyat').AsFloat := NetToplam / qFisDetay.FieldByName('GercekMiktar').AsFloat;
//              qFisDetay.FieldByName('cKdvBirimFiyat').AsFloat := (qFisDetay.FieldByName('cKdvTutar').AsFloat / qFisDetay.FieldByName('Miktar').AsFloat) + NetToplam;

            end;
        end;

      //cNetDovizBirimFiyat

      if (qFisDetay.FieldByName('cNetBirimFiyat').AsFloat > 0) AND (qFisDetay.FieldByName('SatisKur').AsFloat > 0) then
        begin
          qFisDetay.FieldByName('cNetDovizBirimFiyat').AsFloat := (qFisDetay.FieldByName('cNetBirimFiyat').AsFloat / qFisDetay.FieldByName('SatisKur').AsFloat);
        end;

      qFisDetay.FieldByName('cBrutToplam').AsFloat :=  xYuvarla(BrutToplam,2);
//      qFisDetay.FieldByName('cNetToplam').AsFloat :=  xYuvarla(NetToplam,2);
      qFisDetay.FieldByName('cNetToplam').AsFloat :=  xYuvarla(NetToplam,2);



end;

