          q.SQL.Add(' AND BASTAR <= GETDATE() AND A_S = ''S''');
          q.SQL.Add(' ORDER BY INCKEYNO DESC ');
          q.ParamByName('Stk').AsString := qFisDetay.FieldByName('StokKod').AsString;
          q.ParamByName('Car').AsString := qFisBaslik.FieldByName('CariKod').AsString;
          q.Open;
          if q.RecordCount = 1 then
            begin
               // KOSGENEL TABLOSUNDA HANGÝ FÝYAT OLDUĐU YAZIYOR BURAYA BAKILACAK.
              if q1.FieldByName('LISTEFIATI').AsInteger = 1 then BirimFiyat := q.FieldByName('FIYAT1').AsFloat;
              if q1.FieldByName('LISTEFIATI').AsInteger = 2 then BirimFiyat := q.FieldByName('FIYAT2').AsFloat;
              if q1.FieldByName('LISTEFIATI').AsInteger = 3 then BirimFiyat := q.FieldByName('FIYAT3').AsFloat;
              if q1.FieldByName('LISTEFIATI').AsInteger = 4 then BirimFiyat := q.FieldByName('FIYAT4').AsFloat;

    //          BirimFiyat := q.FieldByName('FIYAT1').AsFloat;

              StokParabirimi := q.FieldByName('FIYATDOVIZTIPI').Asstring;

    //          if GelenDoviz = 'TL' then StokParabirimi := '0';

                if (StokParaBirimi = '0') then
                  begin

                     // KOSGENEL TABLOSUNDA HANGÝ FÝYAT OLDUĐU YAZIYOR BURAYA BAKILACAK.
                    if q1.FieldByName('LISTEFIATI').AsInteger = 1 then BirimFiyat := q.FieldByName('FIYAT1').AsFloat;
                    if q1.FieldByName('LISTEFIATI').AsInteger = 2 then BirimFiyat := q.FieldByName('FIYAT2').AsFloat;
                    if q1.FieldByName('LISTEFIATI').AsInteger = 3 then BirimFiyat := q.FieldByName('FIYAT3').AsFloat;
                    if q1.FieldByName('LISTEFIATI').AsInteger = 4 then BirimFiyat := q.FieldByName('FIYAT4').AsFloat;

    //                BirimFiyat := q.FieldByName('FIYAT1').AsFloat;
                    Kur := 1;
                    DovizAdi := 'TL';
                  end;

            end else
            begin
              // GENEL Fiyat grubundan bakýlarak fiyat bulunacak.
              q.Close;
              q.SQL.Clear;
              q.SQL.Add(' SELECT TOP 1 * FROM TBLSTOKFIAT ');
              q.SQL.Add(' WHERE STOKKODU =:Stk AND FIYATGRUBU = ''GENEL'' ');  //
              q.SQL.Add(' AND BASTAR <= GETDATE() AND A_S = ''S''');
              q.SQL.Add(' ORDER BY INCKEYNO DESC ');
              q.ParamByName('Stk').AsString := qFisDetay.FieldByName('StokKod').AsString;;
              q.Open;

                if q.RecordCount = 1 then
                  begin

                    UniMainModule.saFiyat.Title:='FÝYAT BUL';
                    UniMainModule.saFiyat.Show('Satýţ Fiyatý GENEL grubundan bulunmuţtur.');
                    UniMainModule.saFiyat.Show();

                     // KOSGENEL TABLOSUNDA HANGÝ FÝYAT OLDUĐU YAZIYOR BURAYA BAKILACAK.
                    if q1.FieldByName('LISTEFIATI').AsInteger = 1 then BirimFiyat := q.FieldByName('FIYAT1').AsFloat;
                    if q1.FieldByName('LISTEFIATI').AsInteger = 2 then BirimFiyat := q.FieldByName('FIYAT2').AsFloat;
                    if q1.FieldByName('LISTEFIATI').AsInteger = 3 then BirimFiyat := q.FieldByName('FIYAT3').AsFloat;
                    if q1.FieldByName('LISTEFIATI').AsInteger = 4 then BirimFiyat := q.FieldByName('FIYAT4').AsFloat;

          //          BirimFiyat := q.FieldByName('FIYAT1').AsFloat;

                    StokParabirimi := q.FieldByName('FIYATDOVIZTIPI').Asstring;

    //                if GelenDoviz = 'TL' then StokParabirimi := '0';

                      if (StokParaBirimi = '0') then
                        begin

                           // KOSGENEL TABLOSUNDA HANGÝ FÝYAT OLDUĐU YAZIYOR BURAYA BAKILACAK.
                          if q1.FieldByName('LISTEFIATI').AsInteger = 1 then BirimFiyat := q.FieldByName('FIYAT1').AsFloat;
                          if q1.FieldByName('LISTEFIATI').AsInteger = 2 then BirimFiyat := q.FieldByName('FIYAT2').AsFloat;
                          if q1.FieldByName('LISTEFIATI').AsInteger = 3 then BirimFiyat := q.FieldByName('FIYAT3').AsFloat;
                          if q1.FieldByName('LISTEFIATI').AsInteger = 4 then BirimFiyat := q.FieldByName('FIYAT4').AsFloat;

          //                BirimFiyat := q.FieldByName('FIYAT1').AsFloat;
                          Kur := 1;
                          DovizAdi := 'TL';
                        end;

                  end else
                  begin
                    q.Close;
                    q.SQL.Clear;
                    q.SQL.Add(' SELECT SUBE_KODU, STOK_KODU, STOK_ADI, DOV_SATIS_FIAT, SAT_DOV_TIP, SATIS_FIAT1 FROM TBLSTSABIT WHERE STOK_KODU =:Stk ');

                    q.ParamByName('Stk').AsString := qFisDetay.FieldByName('StokKod').AsString;
                    q.Open;
                    BirimFiyat := q.FieldByName('DOV_SATIS_FIAT').AsFloat;
                    StokParabirimi := q.FieldByName('SAT_DOV_TIP').Asstring;

                    if qFisDet.FieldByName('DovizAdi').AsString = 'TL' then StokParabirimi := '0'; // Fiţ Satýrýndaki Döviz Tipi, Aslýnda STSABIT teki dir...

                      if (StokParaBirimi = '0') then
                        begin
                          BirimFiyat := q.FieldByName('SATIS_FIAT1').AsFloat;

                          Kur := 1;
                          DovizAdi := 'TL';
                        end;
                  end;


            end;

          qFisDetay.Edit;
            qFisDetay.FieldByName('BirimFiyat').AsFloat := BirimFiyat;
          qFisDetay.Post;

          if qFisBaslik.State IN [dsEdit,dsInsert] then qFisBaslik.Post;

          if qFisDetay.State IN [dsEdit,dsInsert] then qFisDetay.Post;
              qFisDetay.ApplyUpdates;

          if qEk.State IN [dsEdit,dsInsert] then qEk.Post;
              qEk.ApplyUpdates;


//          frmSiparisDM.qFisDetay.Edit;
//            frmSiparisDM.qFisDetay.FieldByName('Miktar').AsFloat := txtMiktar.Value;
//            frmSiparisDM.qFisDetay.FieldByName('BirimFiyat').AsFloat := txtBirimFiyat.Value;
//            frmSiparisDM.qFisDetay.FieldByName('ParaBirimi').AsString := IntToStr(dovizCombo.KeyValue);
//            frmSiparisDM.qFisDetay.FieldByName('DovizAdi').AsString := Trim(dovizCombo.Text);
//
