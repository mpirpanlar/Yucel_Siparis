      // Siparis Baslik Hatýrla
      qFisBas.Close;
      qFisBas.SQL.Clear;
      qFisBas.SQL.Add(' SELECT FisNo, OzelKod5,CariKod FROM SIPARIS_BASLIK WHERE (FisNo =:Fis) ');
      qFisBas.ParamByName('Fis').AsString := Fis;
      qFisBas.Open;

      // Siparis Detay Hatýrla
      qFisDet.Close;
      qFisDet.SQL.Clear;
