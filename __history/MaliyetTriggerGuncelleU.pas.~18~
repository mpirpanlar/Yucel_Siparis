unit MaliyetTriggerGuncelleU;

interface

uses
  Windows, Messages, SysUtils, Variants, Classes, Graphics,
  Controls, Forms, uniGUITypes, uniGUIAbstractClasses,
  uniGUIClasses, uniGUIForm, uniScreenMask, uniGUIBaseClasses, uniSweetAlert,
  Data.DB, uniGridExporters, uniBasicGrid, Vcl.Menus, uniMainMenu, DBAccess,
  Uni, MemDS, uniDBGrid, uniComboBox, uniMultiItem, uniDBComboBox,
  uniDBLookupComboBox, uniEdit, uniDateTimePicker, uniPanel, uniButton,
  uniBitBtn, uniMenuButton, uniMemo, uniLabel, uniDBText;

type
  TfrmMaliyetTriggerGuncelle = class(TUniForm)
    UniContainerPanel1: TUniContainerPanel;
    UniPanel2: TUniPanel;
    UniMenuButton1: TUniMenuButton;
    UniButton2: TUniButton;
    UniPanel6: TUniPanel;
    btnKaydet: TUniButton;
    btnSil: TUniButton;
    UniPanel1: TUniPanel;
    UniSimplePanel3: TUniSimplePanel;
    UniDateTimePicker1: TUniDateTimePicker;
    edCariKod: TUniEdit;
    cbTrigger: TUniComboBox;
    btnGuncelle: TUniButton;
    UniSimplePanel2: TUniSimplePanel;
    popYazdir: TUniPopupMenu;
    btnHtml: TUniMenuItem;
    btnXls: TUniMenuItem;
    btnCsv: TUniMenuItem;
    saKaydet: TUniSweetAlert;
    UniScreenMask1: TUniScreenMask;
    saMesaj: TUniSweetAlert;
    UniButton1: TUniButton;
    procedure UniFormShow(Sender: TObject);
    procedure UniButton2Click(Sender: TObject);
    procedure btnGuncelleClick(Sender: TObject);
  private
    { Private declarations }
  public
    { Public declarations }
  end;

function frmMaliyetTriggerGuncelle: TfrmMaliyetTriggerGuncelle;

implementation

{$R *.dfm}

uses
  MainModule, uniGUIApplication, SiparisU, Genel, Main, CariDetayU, DMU, TmpU;

function frmMaliyetTriggerGuncelle: TfrmMaliyetTriggerGuncelle;
begin
  Result := TfrmMaliyetTriggerGuncelle(UniMainModule.GetFormInstance(TfrmMaliyetTriggerGuncelle));
end;

procedure TfrmMaliyetTriggerGuncelle.btnGuncelleClick(Sender: TObject);
var
  q:TUniQuery;
begin
  try
    q := TUniQuery.Create(nil);
    q.Connection := frmDM.conNetsis;

    if cbTrigger.ItemIndex = 0 then
      begin
        q.Close;
        q.SQL.Clear;
        q.SQL.Add('ENABLE TRIGGER DBO.PLTR_MALIYET_KONTROL ON TBLSTHAR');
        q.ExecSQL;

        q.Close;
        q.SQL.Clear;
        q.SQL.Add('INSERT INTO PLT_TRIGGER_AK_LOG(TRIGGER_ADI,A_K,TARIH,KAYITYAPANKUL)');
        q.SQL.Add(' VALUES(''PLTR_MALIYET_KONTROL'',0,GETDATE(),:Kul)');
        q.ParamByName('Kul').AsString := Tmp.xKullaniciAdi;
        q.ExecSQL;
        q.Close;

        FreeAndNil(q);
        saMesaj.Show('Maliyet Kontrol Açýldý');
      end;

    if cbTrigger.ItemIndex = 1 then
      begin
        q.Close;
        q.SQL.Clear;
        q.SQL.Add('DISABLE TRIGGER DBO.PLTR_MALIYET_KONTROL ON TBLSTHAR');
        q.ExecSQL;

        q.Close;
        q.SQL.Clear;
        q.SQL.Add('INSERT INTO PLT_TRIGGER_AK_LOG(TRIGGER_ADI,A_K,TARIH,KAYITYAPANKUL)');
        q.SQL.Add(' VALUES(''PLTR_MALIYET_KONTROL'',1,GETDATE(),:Kul)');
        q.ParamByName('Kul').AsString := Tmp.xKullaniciAdi;
        q.ExecSQL;
        q.Close;

        FreeAndNil(q);
        saMesaj.Show('Maliyet Kontrol Kapatýldý');
      end;



  except
    On E:Exception do
      begin
        q.Close;
        FreeAndNil(q);
        UniMainModule.saHata.Show('Kayýt Hatasý -> ' + E.Message);
        Abort;
      end;


  end;
end;

procedure TfrmMaliyetTriggerGuncelle.UniButton2Click(Sender: TObject);
begin
    MainForm.NavPage.ActivePage.Close;
end;

procedure TfrmMaliyetTriggerGuncelle.UniFormShow(Sender: TObject);
var
  q:TUniQuery;
begin

  try
    q := TUniQuery.Create(nil);
    q.Connection := frmDM.conNetsis;

      begin
        q.Close;
        q.SQL.Clear;
        q.SQL.Add(' SELECT name, is_disabled FROM sys.triggers WHERE name = ''PLTR_MALIYET_KONTROL'' ');
        q.Open;
        if q.FieldByName('is_disabled').Value = False then cbTrigger.ItemIndex := 1;
        if q.FieldByName('is_disabled').Value = True then cbTrigger.ItemIndex := 0;

        q.Close;
        FreeAndNil(q);
      end;

  except
    q.Close;
    FreeAndNil(q);
    saMesaj.Show('Maliyet durumu sorgulanamadý.');
    Abort;
  end;
end;

end.
