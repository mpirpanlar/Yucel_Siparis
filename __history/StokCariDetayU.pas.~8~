unit StokCariDetayU;

interface

uses
  Windows, Messages, SysUtils, Variants, Classes, Graphics,
  Controls, Forms, uniGUITypes, uniGUIAbstractClasses,
  uniGUIClasses, uniGUIForm, uniGUIBaseClasses, uniPanel, uniBasicGrid,
  uniDBGrid, Data.DB, DBAccess, Uni, MemDS;

type
  TfrmStokCariDetay = class(TUniForm)
    UniContainerPanel1: TUniContainerPanel;
    UniDBGrid1: TUniDBGrid;
    qStokCariDetay: TUniQuery;
    dStokCariDetay: TUniDataSource;
    procedure UniFormShow(Sender: TObject);
  private
    { Private declarations }
  public
    { Public declarations }
    Cari, Stok, Depo : String;
  end;

function frmStokCariDetay: TfrmStokCariDetay;

implementation

{$R *.dfm}

uses
  MainModule, uniGUIApplication, DMU;

function frmStokCariDetay: TfrmStokCariDetay;
begin
  Result := TfrmStokCariDetay(UniMainModule.GetFormInstance(TfrmStokCariDetay));
end;

procedure Sorgula(Cari,Stok,Depo:String);
begin
  with frmStokCariDetay.qStokCariDetay do
    begin
      Close;
      SQL.Clear;
      SQL.Add('');
      SQL.Add('  ');
      SQL.Add(' SELECT H.STOK_KODU, S.STOK_ADI, H.FISNO, H.STHAR_TARIH AS TARIH, H.STHAR_ACIKLAMA AS CARI_KOD, C.CARI_ISIM, H.DEPO_KODU ');
      SQL.Add(' , H.STHAR_GCMIK AS MIKTAR, H.STHAR_DOVTIP AS DOV_TIP, CASE WHEN H.STHAR_DOVTIP = 0 THEN ''TL'' ELSE D.ISIM END ''DOVIZ'', H.STHAR_DOVFIAT AS DOV_FIAT, H.STHAR_NF AS NET_FIAT, STHAR_KDV AS KDV ');
      SQL.Add('  ');
      SQL.Add(' FROM TBLSTHAR H ');
      SQL.Add(' LEFT JOIN TBLSTSABIT S WITH(NOLOCK) ON (S.STOK_KODU = H.STOK_KODU) ');
      SQL.Add(' LEFT JOIN TBLCASABIT C WITH(NOLOCK) ON (C.CARI_KOD = H.STHAR_ACIKLAMA) ');
      SQL.Add(' LEFT JOIN NETSIS.DBO.KUR D WITH(NOLOCK) ON (D.SIRA = H.STHAR_DOVTIP) ');
      SQL.Add(' WHERE H.STOK_KODU =:Stok ');
      SQL.Add(' AND H.STHAR_ACIKLAMA =:Cari  ');
      SQL.Add(' AND H.STHAR_FTIRSIP = ''1'' '); // Sadece Satżž Faturalarż
      SQL.Add(' AND H.DEPO_KODU =:Depo '); // Kullanici Depo
        ParamByName('Stok').AsString := Stok;
        ParamByName('Cari').AsString := Cari;
        ParamByName('Depo').AsString := Depo;
      Open;
      Application.ProcessMessages;

    end;


end;

procedure TfrmStokCariDetay.UniFormShow(Sender: TObject);
begin
  Sorgula(Cari,Stok,Depo);
end;

end.
