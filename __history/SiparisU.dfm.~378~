  object qCari: TUniQuery
    Connection = frmDM.conNetsis
    SQL.Strings = (
      
        '-- SELECT  '#39'MUHTELIF'#39' AS '#39'KAYNAK'#39', VKN_TCKN,CARI_KODU,CARI_ISIM,' +
        'CARI_ADRES,CARI_IL,CARI_ILCE,CARI_EPOSTA,CARI_TEL,KULLANICI_ADI,' +
        'VERGI_DAIRESI'
      
        '-- , 0 AS '#39'CM_BORCT'#39', 0 AS '#39'CM_ALACT'#39', 0 AS '#39'BAKIYE'#39', 0 as VADE_' +
        'GUNU, 0 AS ISKONTO_ORANI, 0 AS '#39'RISKLIMITI'#39
      '-- FROM PLT_CARIKAYDET'
      '--  WHERE CARI_KODU LIKE '#39'12048%'#39
      '-- UNION '
      'SELECT '#39'CARIKART'#39' AS '#39'KAYNAK'#39
      '--, VERGI_NUMARASI'
      
        ', CASE WHEN VERGI_NUMARASI IS NULL THEN (SELECT E.TCKIMLIKNO FRO' +
        'M TBLCASABITEK E WHERE E.CARI_KOD = TBLCASABIT.CARI_KOD) ELSE VE' +
        'RGI_NUMARASI END '#39'VERGI_NUMARASI'#39
      
        ', CARI_KOD, CARI_ISIM, CARI_ADRES, CARI_IL, CARI_ILCE, EMAIL, CA' +
        'RI_TEL, '#39#39' AS '#39'KULLANICI_ADI'#39', VERGI_DAIRESI'
      
        ', CM_BORCT, CM_ALACT, (CM_BORCT-CM_ALACT) AS '#39'BAKIYE'#39', VADE_GUNU' +
        ', ISKONTO_ORANI, ISNULL(R.RISKLIMITI,0) AS RISKLIMITI'
      'FROM TBLCASABIT '
      
        #9'LEFT JOIN TBLCARISK R WITH(NOLOCK) ON (R.CARIKOD = TBLCASABIT.C' +
        'ARI_KOD)'
      'WHERE CARI_TIP = '#39'A'#39
      ' AND CARI_KOD LIKE '#39'12048%'#39
      'ORDER BY CARI_KOD DESC')
    Left = 568
    Top = 118
