procedure TfrmYuklemeTalebi.btnListeleClick(Sender: TObject);
Var
CariAdi :String;
SL: TStringList;
i:integer;

begin

  qSiparis.Close;
  qSiparis.SQL.Clear;
  SQL:='SELECT '
  +' FISNO '
  +' ,S.STHAR_TARIH '
  +' ,S.STOK_KODU, ST.STOK_ADI '
  +' ,S.STHAR_GCMIK '
  +' ,S.STHAR_GCMIK2 '
  +' ,S.STHAR_GCMIK AS MIKTAR1 '
  +' ,ST.OLCU_BR1 '
  +' ,S.STHAR_GCMIK * (ST.PAY_1/ST.PAYDA_1) AS MIKTAR2 '
  +' ,ST.OLCU_BR2 '
  +' ,S.STHAR_GCMIK * (ST.PAY2/ST.PAYDA2) AS MIKTAR3 '
  +' ,ST.OLCU_BR3 '
  +' ,T.ACIKLAMA1 AS DETAY1 '
  +' ,T.ACIKLAMA2 AS DETAY2 '
  +' ,T.ACIKLAMA3 AS DETAY3 '
  +' ,T.ACIKLAMA4 AS DETAY4 '
  +' ,T.ACIKLAMA5 AS DETAY5 '
  +' ,T.ACIKLAMA6 AS DETAY6 '
  +' ,T.ACIKLAMA7 AS DETAY7 '
  +' ,T.ACIKLAMA8 AS DETAY8 '
  +' ,T.ACIKLAMA9 AS DETAY9 '
  +' ,T.ACIKLAMA10 AS DETAY10 '
  +' ,S.CEVRIM '
  +' ,S.STHAR_GCKOD '
  +' ,ISNULL(S.STHAR_NF,0) AS STHAR_NF '
  +' ,ISNULL(S.STHAR_BF,0) AS STHAR_BF '
  +' ,ISNULL(S.STHAR_IAF,0) AS STHAR_IAF '
  +' ,S.STHAR_KDV '
  +' ,S.DEPO_KODU '
  +' ,S.STHAR_ACIKLAMA, C.CARI_ISIM '
  +' ,S.STHAR_SATISK '
  +' ,S.STHAR_MALFISK '
  +' ,S.STHAR_FTIRSIP '
  +' ,S.STHAR_SATISK2 '
  +' ,S.LISTE_FIAT '
  +' ,S.STHAR_HTUR '
  +' ,S.STHAR_DOVTIP '
  +' ,S.STHAR_DOVFIAT '
  +' ,S.STHAR_ODEGUN '
  +' ,S.STRA_SATISK3 '
  +' ,S.STRA_SATISK4 '
  +' ,S.STRA_SATISK5 '
  +' ,S.STRA_SATISK6 '
  +' ,S.STHAR_BGTIP '
  +' ,S.STHAR_KOD1 '
  +' ,S.STHAR_KOD2 '
  +' ,S.STHAR_SIPNUM '
  +' ,S.STHAR_CARIKOD '
  +' ,S.STHAR_SIP_TURU '
  +' ,S.PLASIYER_KODU '
  +' ,S.EKALAN_NEDEN '
  +' ,S.EKALAN '
  +' ,S.EKALAN1 '
  +' ,S.REDMIK '
  +' ,S.REDNEDEN '
  +' ,S.SIRA '
  +' ,S.STRA_SIPKONT '
  +' ,S.AMBAR_KABULNO '
  +' ,S.FIRMA_DOVTIP '
  +' ,S.FIRMA_DOVMAL '
  +' ,S.UPDATE_KODU '
  +' ,S.IRSALIYE_NO '
  +' ,S.IRSALIYE_TARIH '
  +' ,S.KOSULKODU '
  +' ,S.STHAR_TESTAR '
  +' ,S.OLCUBR '
  +' ,S.INCKEYNO '
  +' ,S.VADE_TARIHI '
  +' ,S.LISTE_NO '
  +' ,S.BAGLANTI_NO '
  +' ,S.SUBE_KODU '
  +' ,S.PROJE_KODU '
  +' ,S.FIYATTARIHI '
  +' ,S.KOSULTARIHI '
  +' ,S.STRA_IRSKONT '
  +' ,ST.GRUP_KODU '
  +' ,ST.KOD_1 '
  +' ,ST.KOD_2 '
  +' ,ST.KOD_3 '
  +' ,ST.KOD_4 '
  +' ,ST.KOD_5 '
  +' ,YEAR(STHAR_TARIH) AS TARIH_YIL '
  +' ,MONTH(STHAR_TARIH) AS TARIH_AY '
  +' ,DAY(STHAR_TARIH) AS TARIH_GUN '
  +' ,YEAR(STHAR_TESTAR) AS TESLIMTARIH_YIL '
  +' ,MONTH(STHAR_TESTAR) AS TESLIMTARIH_AY '
  +' ,DAY(STHAR_TESTAR) AS TESLIMTARIH_GUN '
  +' ,M.KOD1 AS BASLIK_KOD1, M.KOD2 AS BASLIK_KOD2, M.ODEKOD, M.SIPARIS_TEST AS BASLIKTESLIM_TARIHI, M.KOSULKODU AS BASLIK_KOSULKODU, M.FIYATTARIHI AS BASLIK_FIYATTARIHI '
  +' ,M.GEN_ISK1T, M.GEN_ISK2T, M.GEN_ISK3T, M.GEN_ISK1O, M.GEN_ISK2O, M.GEN_ISK3O, BRUTTUTAR, M.KDV_DAHIL_BRUT_TOP, M.GENELTOPLAM, M.TOPLAM_MIK '
  +' ,S.FIRMA_DOVTUT, (S.STHAR_GCMIK - S.FIRMA_DOVTUT) AS ''SIP_KALAN'' '
  +' ,0 AS ''KAPALI_YUKLEME_MIKTAR'' '
  +' , Y.MIKTAR AS ''ACIK_YUKLEME_MIKTAR'' '
  +' , M.ODEMEGUNU '
  +' FROM ' + xNetsisSirketKodu + '.DBO.TBLSIPATRA S  WITH(NOLOCK,NOWAIT) '
  +' LEFT OUTER JOIN ' + xNetsisSirketKodu + '.DBO.TBLSSATIRAC T WITH(NOLOCK,NOWAIT) ON (T.INCKEYNO = S.INCKEYNO) AND (T.SIRANO = S.SIRA) AND (BGTIP = S.STHAR_FTIRSIP) '
  +' LEFT OUTER JOIN ' + xNetsisSirketKodu + '.DBO.TBLSTSABIT ST WITH(NOLOCK,NOWAIT) ON (ST.STOK_KODU = S.STOK_KODU) '
  +' LEFT OUTER JOIN ' + xNetsisSirketKodu + '.DBO.TBLCASABIT C WITH(NOLOCK,NOWAIT) ON (C.CARI_KOD = S.STHAR_ACIKLAMA) '
  +' LEFT OUTER JOIN ' + xNetsisSirketKodu + '.DBO.TBLSIPAMAS M WITH(NOLOCK,NOWAIT) ON (M.SUBE_KODU = S.SUBE_KODU) AND (M.FATIRS_NO = S.FISNO) '
  +' LEFT OUTER JOIN ASYA_ENTEGRE.DBO.HV_INCKEY_MIKTAR Y WITH(NOLOCK) ON (Y.SIPINCKEY = S.INCKEYNO) '
  +' WHERE (S.STHAR_FTIRSIP = ''6'') AND (S.STHAR_HTUR <> ''K'') AND (S.SUBE_KODU =:Sub) AND (S.DEPO_KODU =:Dep)'
  +' AND (S.STHAR_TARIH BETWEEN :t1 AND :t2)';

  SL := TStringList.Create;
  SL.Delimiter := ' ';//Boţluk
  SL.DelimitedText := edCariKod.Text;

   if edCariKod.Text <> '' then begin
        for i:=0 to SL.Count-1 do begin
          CariAdi:=SL.Strings[i];
          SQL:= SQL+' and ((S.STHAR_ACIKLAMA like''%'+CariAdi+'%'') or (C.CARI_ISIM like''%'+CariAdi+'%'') or (S.FISNO like''%'+CariAdi+'%'')) ';
        end;
   end;

  if not chkSipKalan.Checked = True then
    begin
      SQL:= SQL+' AND ((S.STHAR_GCMIK - S.FIRMA_DOVTUT) > 0) ';
    end;

  qSiparis.SQL.Text:=SQL;
  qSiparis.ParamByName('t1').Value:=UniDateTimePicker1.DateTime;
  qSiparis.ParamByName('t2').Value:=UniDateTimePicker2.DateTime;
  qSiparis.ParamByName('Sub').AsInteger := xSubeKodu;
  qSiparis.ParamByName('Dep').AsInteger := xKullaniciDepo;
  qSiparis.SQL.Add('ORDER BY S.FISNO, S.INCKEYNO ASC');

  qSiparis.Open;
  SL.Free;

  mSiparis.Close;
  mSiparis.Open;
  mSiparis.DisableControls;
  mSiparis.LoadFromDataSet(qSiparis);
  mSiparis.EnableControls;

    rgirsFat.Enabled := True;
    rgirsFat.ItemIndex := -1;

    rgOdeme.Enabled := True;
    rgOdeme.ItemIndex := -1;

    rgDoviz.Enabled := True;
    rgDoviz.ItemIndex := -1;



end;

function TfrmYuklemeTalebi.YuklemeNoGetir:String;
var
  UretimNo : String;
  q1 : TUniQuery;
begin

  q1 := TUniQuery.Create(nil);
