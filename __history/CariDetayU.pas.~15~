unit CariDetayU;

interface

uses
  Windows, Messages, SysUtils, Variants, Classes, Graphics,
  Controls, Forms, uniGUITypes, uniGUIAbstractClasses,
  uniGUIClasses, uniGUIForm, uniBasicGrid, uniDBGrid, uniGUIBaseClasses,
  uniPanel, Data.DB, DBAccess, Uni, MemDS, uniButton, uniBitBtn, uniMenuButton;

type
  TfrmCariDetay = class(TUniForm)
    UniContainerPanel1: TUniContainerPanel;
    UniDBGrid1: TUniDBGrid;
    qCariDetay: TUniQuery;
    dCariDetay: TUniDataSource;
    qCariDetayCARI_KOD: TStringField;
    qCariDetayCARI_ISIM: TStringField;
    qCariDetayTARIH: TDateTimeField;
    qCariDetayCARI_TIP: TStringField;
    qCariDetayHAREKET_TURU: TStringField;
    qCariDetayHAREKET: TStringField;
    qCariDetayVADE_TARIHI: TDateTimeField;
    qCariDetayBELGE_NO: TStringField;
    qCariDetayACIKLAMA: TStringField;
    qCariDetayBORC: TFloatField;
    qCariDetayALACAK: TFloatField;
    qCariDetayBAKIYE: TFloatField;
    qCariDetayINC_KEY_NUMBER: TIntegerField;
    qCariDetayKAPATILMIS_TUTAR: TFloatField;
    UniPanel2: TUniPanel;
    btnDetayGoster: TUniButton;
    pnlFaturaDetay: TUniPanel;
    UniButton2: TUniButton;
    gridFaturaDetay: TUniDBGrid;
    dFaturaDetay: TUniDataSource;
    qFaturaDetay: TUniQuery;
    procedure UniFormShow(Sender: TObject);
    procedure btnDetayGosterClick(Sender: TObject);
    procedure UniButton2Click(Sender: TObject);
  private
    { Private declarations }
  public
    { Public declarations }
    CariKod : String;
  end;

function frmCariDetay: TfrmCariDetay;

implementation

{$R *.dfm}

uses
  MainModule, uniGUIApplication;

procedure Sorgula(CariKod:String);
begin
  with frmCariDetay.qCariDetay do
    begin
      Close;
      SQL.Clear;
      SQL.Add(' SELECT * FROM HV_CAHAR WHERE CARI_KOD =:Car ORDER BY TARIH DESC');
        ParamByName('Car').AsString := CariKod;
      Open;
      Application.ProcessMessages;
    end;


end;

function frmCariDetay: TfrmCariDetay;
begin
  Result := TfrmCariDetay(UniMainModule.GetFormInstance(TfrmCariDetay));
end;

procedure TfrmCariDetay.btnDetayGosterClick(Sender: TObject);
begin
  if not pnlFaturaDetay.Visible = True then pnlFaturaDetay.Visible := True else pnlFaturaDetay.Visible := False;
  if not gridFaturaDetay.Visible = True then gridFaturaDetay.Visible := True else gridFaturaDetay.Visible := False;
end;

procedure TfrmCariDetay.UniButton2Click(Sender: TObject);
begin
  if not pnlFaturaDetay.Visible = False then pnlFaturaDetay.Visible := False else pnlFaturaDetay.Visible := True;
  if not gridFaturaDetay.Visible = False then gridFaturaDetay.Visible := False else gridFaturaDetay.Visible := True;
end;

procedure TfrmCariDetay.UniFormShow(Sender: TObject);
begin

  if not pnlFaturaDetay.Visible = False then pnlFaturaDetay.Visible := False else pnlFaturaDetay.Visible := True;
  if not gridFaturaDetay.Visible = False then gridFaturaDetay.Visible := False else gridFaturaDetay.Visible := True;

  Sorgula(CariKod);
end;

end.
