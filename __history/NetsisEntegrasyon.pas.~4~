procedure NetsisDekontGelenHavale();
var
  Kernel : IKernel;
  Sirket : ISirket;
  DekontMas : IDekomas;
  Dekont : IDekont;
  Bankaid : string;
  qry : TUniQuery;
begin

  Screen.Cursor:=crHourGlass;

  Kullanici:=DM.qLogo.FieldByName('NetsisKullanici').AsString;
  Sifre:=DM.qLogo.FieldByName('NetsisSifre').AsString;
  Firma:=DM.qLogo.FieldByName('NetsisFirma').AsString;

  if Kernel = nil then
    begin
      try
        if Kernel <> nil then
          begin
            Kernel.FreeNetsisLibrary;
            Kernel := nil;
            Kernel:=CoKernel.Create;
          end else
          begin
            Kernel := nil;
            Kernel := CoKernel.Create;
          end;

        if Sirket <> nil then
          begin
            Sirket := nil;
          end else
          begin
            Sirket := nil;
            Sirket := Kernel.yeniSirket(vtMSSQL, Firma, 'TemelSet', '', Kullanici, Sifre, 0);
          end;


//        Sirket := Kernel.yeniSirket(vtMSSQL, txtSirket1.Text, 'TemelSet', '', 'BYS2', 'BYS3', 0);
      except
        On E:Exception do
          begin
            Screen.Cursor := crDefault;
            ShowMessage('Bađlantý Hatasý -> ' + E.Message);
            Abort;
          end;
      end;
    end;

    Qry:=Tuniquery.Create(nil);
    Qry.Connection:=DM.UC;

    Bankaid := CariFis.qFisBaslik.FieldByName('kasa_id').AsString;
    xTabloAc(qry,'Select LogoKodu From TKasa Where Kasa_id = '''+Bankaid+'''');

    DekontMas := Kernel.yeniDekomas(Sirket);
    DekontMas.YeniNumaraAl('HV');
    AktifDekontNo := 0;
    AktifDekontNo := DekontMas.Dekont_No;

     Try
       // Banka Satýrý
       Dekont := DekontMas.KalemEkle(dekBanka);
       Dekont.Kod := qry.FieldByName('LogoKodu').AsString;
       Dekont.C_M := 'B';
       Dekont.Plasiyer := '01';
       Dekont.Tutar := CariFis.qFisBaslik.FieldByName('alacak').AsFloat;
       Dekont.B_A := 'B'; // Borç - Alacak
       Dekont.Tarih := CariFis.qFisBaslik.FieldByName('tarih').AsDateTime;
       Dekont.Aciklama1 :=  'GELEN HAVALE ' + CariFis.qFisBaslik.FieldByName('cari_kod').AsString + ' ' + CariFis.qFisBaslik.FieldByName('aciklama').AsString;
       Dekont.DovTL := 'T';

        Try
          dekont.BDekont(doEkle);
        Except
           On E:Exception Do
               Begin
                ShowMessage('Dekont Banka kaydý yapýlýrken hata oluţtu. '+#13#10+'Dönen Hata: '+Kernel.SonNetsisHata.Hata);
                Exit;
               End;
        End;

       // Cari Satýrý
       Dekont := DekontMas.KalemEkle(dekCari);
       Dekont.Kod := CariFis.qFisBaslik.FieldByName('cari_kod').AsString;
       Dekont.C_M := 'C';
       Dekont.Plasiyer := '01';
       Dekont.Tutar := CariFis.qFisBaslik.FieldByName('alacak').AsFloat;
       Dekont.B_A := 'A'; // Borç - Alacak
       Dekont.Tarih := CariFis.qFisBaslik.FieldByName('tarih').AsDateTime;
       Dekont.Aciklama1 :=  'GELEN HAVALE ' + qry.FieldByName('LogoKodu').AsString + ' ' + CariFis.qFisBaslik.FieldByName('aciklama').AsString;
       Dekont.DovTL := 'T';

        Try
          dekont.CDekont(doEkle);
        Except
           On E:Exception Do
               Begin
                ShowMessage('Dekont Cari kaydý yapýlýrken hata oluţtu. '+#13#10+'Dönen Hata: '+Kernel.SonNetsisHata.Hata);
                Exit;
               End;
        End;

        Try
          if DekontMas.BelgeGetir('HV',AktifDekontNo) then
            begin
              DekontMas.Tamamla;
            end;

        Except
           On E:Exception Do
               Begin
                ShowMessage('Dekont Tamamlama iţlemi sýrasýnda hata oluţtu. '+#13#10+'Dönen Hata: '+Kernel.SonNetsisHata.Hata);
                Exit;
               End;
        End;

     Finally
       Dekont := nil;
       DekontMas := nil;
       Sirket := nil;
       Kernel.FreeNetsisLibrary;
       Kernel := nil;
     End;


    try
      ShowMessage('Dekont kayýt iţlemi baţarýyla tamamlandý');
    except
      On E:Exception do
        begin
          Screen.Cursor := crDefault;
          ShowMessage('Dekont Kayýt Hatasý -> ' + E.Message);
          Abort;
        end;
    end;

   Screen.Cursor := crDefault;

end;

