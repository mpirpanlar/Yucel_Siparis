    begin
      try
        Kernel:=CoKernel.Create;
        Sirket := Kernel.yeniSirket(vtMSSQL, Firma, 'TemelSet', '', Kullanici, Sifre, 0);
      except
        On E:Exception do
          begin
            ShowMessage('Bađlantý Hatasý -> ' + E.Message);
            Abort;
          end;
      end;
    end;

  Stok := Kernel.yeniStok(Sirket);
  StokTemel := Stok.TemelBilgi;
  StokEk := Stok.EkBilgi;
  Stok.NetsisTransaction(ttBaslat);

  Try
    StokTemel.Stok_Kodu := StokKart.qTstk.FieldByName('stok_kod').AsString;
    StokTemel.Stok_Adi := StokKart.qTstk.FieldByName('stok_ad').AsString;
    StokTemel.Satis_Fiat1 := StokKart.qTstk.FieldByName('s_fiyat').AsFloat;
    StokTemel.Alis_Fiat1 := StokKart.qTstk.FieldByName('a_fiyat').AsFloat;
    StokTemel.KDV_Orani := StokKart.qTstk.FieldByName('kdv').AsFloat;
    StokTemel.Alis_Kdv_Kodu := StokKart.qTstk.FieldByName('kdv').AsFloat;

      if StokKart.qTstk.FieldByName('LogoBirimKodu').AsString<>'' then
          StokTemel.Olcu_Br1 := StokKart.qTstk.FieldByName('LogoBirimKodu').AsString
        else StokTemel.Olcu_Br1 := 'AD';

    StokTemel.Pay_1 := 1;
    StokTemel.Payda_1 := 1;
    StokTemel.Pay2 := 1;
    StokTemel.Payda2 := 1;


    StokEk.Stok_Kodu := StokKart.qTstk.FieldByName('stok_kod').AsString;
    StokEk.Ingisim := '';
    Stok.kayitYeni;
    Stok.NetsisTransaction(ttBitir);

    ShowMessage('Netsis aktarým baţarýlý.');

  Except
    Stok.NetsisTransaction(ttGeriAl);
    Raise;
  End;

End;


