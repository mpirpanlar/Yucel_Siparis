  Sifre:=DM.qLogo.FieldByName('NetsisSifre').AsString;
  Firma:=DM.qLogo.FieldByName('NetsisFirma').AsString;

  if Kernel = nil then
    begin
      try
        Kernel:=CoKernel.Create;
        Sirket := Kernel.yeniSirket(vtMSSQL, Firma, 'TemelSet', '', Kullanici, Sifre, 0);
      except
        On E:Exception do
          begin
            ShowMessage('Bađlantý Hatasý -> ' + E.Message);
            Abort;
          end;
      end;
    end;

  muPlan := Kernel.YeniMuPlan(Sirket);
  muPlanTemel := muPlan.TemelBilgi;
  muPlanEk := muPlan.EkBilgi;

  //Yeni kayýt
  muPlan.NetsisTransaction (ttBaslat);
    Try

      MuplanTemel.Hesap_Kodu := CariKart.qTcr.FieldByName('MuhasebeKodu').AsString;
      muPlanTemel.Hs_Adi := CariKart.qTcr.FieldByName('Cari_ad').AsString;
      muPlanTemel.Agm := 'M';

      if Copy(CariKart.qTcr.FieldByName('MuhasebeKodu').AsString,1,3) = '120' then begin
        muPlanTemel.Calis_Tip := 'B';
      end else if Copy(CariKart.qTcr.FieldByName('MuhasebeKodu').AsString,1,3) = '320'then begin
        muPlanTemel.Calis_Tip := 'A';
      end;



//      muPlanTemel.Calis_Bag := 'F';

      muPlanEk.Kod := CariKart.qTcr.FieldByName('MuhasebeKodu').AsString;


      muPlan.kayitYeni();

      muPlan.NetsisTransaction (ttBitir);

      ShowMessage('Netsis aktarým tamamlandý.');

    Except
      muPlan.NetsisTransaction (ttGeriAl);
      Raise;
    End;


End;
