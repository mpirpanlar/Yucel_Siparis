procedure NetsisSatisFaturasi();
Var
  Kernel : IKernel;
  Sirket : ISirket;
  NetsisFatura : IFatura;
  NetsisFatUst : IFatUst;
  NetsisFatKalem : IFatKalem;
  Qry : TUniQuery;
  FisNo : String;
begin

  Screen.Cursor:=crHourGlass;

  Kullanici:=DM.qLogo.FieldByName('NetsisKullanici').AsString;
  Sifre:=DM.qLogo.FieldByName('NetsisSifre').AsString;
  Firma:=DM.qLogo.FieldByName('NetsisFirma').AsString;

  if Kernel = nil then
    begin
      try
        Kernel:=CoKernel.Create;
        Sirket := Kernel.yeniSirket(vtMSSQL, Firma, 'TemelSet', '', Kullanici, Sifre, 0);
//        Sirket := Kernel.yeniSirket(vtMSSQL, txtSirket1.Text, 'TemelSet', '', 'BYS2', 'BYS3', 0);
      except
        On E:Exception do
          begin
            Screen.Cursor := crDefault;
            ShowMessage('Bađlantý Hatasý -> ' + E.Message);
            Abort;
          end;
      end;
    end;

  Qry:=Tuniquery.Create(nil);
  Qry.Connection:=DM.UC;
  FisNo:=Fatura.qFaturaBaslik.FieldByName('fis_no').AsString;

  NetsisFatura := Kernel.yeniFatura(Sirket, ftSFat);

  //Fatura Ust Bilgilerini Olustur
  NetsisFatUst := NetsisFatura.Ust;
  NetsisFatUst.FATIRS_NO := Fatura.qFaturaBaslik.FieldByName('Belge_No').AsString;
  NetsisFatUst.TIPI := ft_Acik;

  NetsisFatUst.CariKod := Fatura.qFaturaBaslik.FieldByName('Cari_Kod').AsString;
  NetsisFatUst.TARIH := Fatura.qFaturaBaslik.FieldByName('Tarih').AsDateTime;
  NetsisFatUst.SIPARIS_TEST := Fatura.qFaturaBaslik.FieldByName('Tarih').AsDateTime;
  NetsisFatUst.ODEMETARIHI := Fatura.qFaturaBaslik.FieldByName('Vade').AsDateTime;
  NetsisFatUst.Aciklama := Fatura.qFaturaBaslik.FieldByName('Aciklama').AsString;
  NetsisFatUst.FIYATTARIHI := Fatura.qFaturaBaslik.FieldByName('Tarih').AsDateTime;
  NetsisFatUst.ENTEGRE_TRH := Fatura.qFaturaBaslik.FieldByName('Tarih').AsDateTime;

  Fatura.qFaturaDetay.First;
    while not Fatura.qFaturaDetay.Eof do
      begin

        NetsisFatKalem := NetsisFatura.kalemYeni(Fatura.qFaturaDetay.FieldByName('stok_kod').AsString);
        NetsisFatKalem.STra_GCMIK := Fatura.qFaturaDetay.FieldByName('miktar').AsFloat;
        NetsisFatKalem.STra_BF := Fatura.qFaturaDetay.FieldByName('NetBirimFiyat').AsFloat;
        NetsisFatKalem.DEPO_KODU := 1;

//        NetsisFatKalem.STra_SatIsk := Fatura.qFaturaDetay.FieldByName('isk_1').AsFloat;
//        NetsisFatKalem.STra_SatIsk2 := Fatura.qFaturaDetay.FieldByName('isk_2').AsFloat;
//        NetsisFatKalem.STra_SatIsk3 := Fatura.qFaturaDetay.FieldByName('isk_3').AsFloat;
//        NetsisFatKalem.STra_SatIsk4 := Fatura.qFaturaDetay.FieldByName('isk_4').AsFloat;
//        NetsisFatKalem.STra_SatIsk5 := Fatura.qFaturaDetay.FieldByName('isk_5').AsFloat;


        Fatura.qFaturaDetay.Next;
      end;


  //Kayýtlarý saklama
  NetsisFatura.kayitYeni;
  ShowMessage('kayýt tamamlandý.');

  NetsisFatKalem := nil;
  NetsisFatUst := nil;
  NetsisFatura := nil;
  Sirket := nil;
  Kernel := nil;
//  Kernel.FreeNetsisLibrary;

  Screen.Cursor := crDefault;

end;

procedure NetsisAlisFaturasi();
Var
  Kernel : IKernel;
  Sirket : ISirket;
  NetsisFatura : IFatura;
  NetsisFatUst : IFatUst;
  NetsisFatKalem : IFatKalem;
  Qry : TUniQuery;
  FisNo : String;
begin

  Screen.Cursor:=crHourGlass;

  Kullanici:=DM.qLogo.FieldByName('NetsisKullanici').AsString;
  Sifre:=DM.qLogo.FieldByName('NetsisSifre').AsString;
  Firma:=DM.qLogo.FieldByName('NetsisFirma').AsString;

  if Kernel = nil then
    begin
      try
        Kernel:=CoKernel.Create;
        Sirket := Kernel.yeniSirket(vtMSSQL, Firma, 'TemelSet', '', Kullanici, Sifre, 0);
//        Sirket := Kernel.yeniSirket(vtMSSQL, txtSirket1.Text, 'TemelSet', '', 'BYS2', 'BYS3', 0);
      except
        On E:Exception do
          begin
            ShowMessage('Bađlantý Hatasý -> ' + E.Message);
            Abort;
          end;
      end;
    end;

  Qry:=Tuniquery.Create(nil);
  Qry.Connection:=DM.UC;
  FisNo:=Fatura.qFaturaBaslik.FieldByName('fis_no').AsString;

  NetsisFatura := Kernel.yeniFatura(Sirket, ftAFat);

  //Fatura Ust Bilgilerini Olustur
  NetsisFatUst := NetsisFatura.Ust;
  NetsisFatUst.FATIRS_NO := Fatura.qFaturaBaslik.FieldByName('Belge_No').AsString;
  NetsisFatUst.TIPI := ft_Acik;

  NetsisFatUst.CariKod := Fatura.qFaturaBaslik.FieldByName('Cari_Kod').AsString;
  NetsisFatUst.TARIH := Fatura.qFaturaBaslik.FieldByName('Tarih').AsDateTime;
  NetsisFatUst.SIPARIS_TEST := Fatura.qFaturaBaslik.FieldByName('Tarih').AsDateTime;
  NetsisFatUst.ODEMETARIHI := Fatura.qFaturaBaslik.FieldByName('Vade').AsDateTime;
  NetsisFatUst.Aciklama := Fatura.qFaturaBaslik.FieldByName('Aciklama').AsString;
  NetsisFatUst.FIYATTARIHI := Fatura.qFaturaBaslik.FieldByName('Tarih').AsDateTime;
  NetsisFatUst.ENTEGRE_TRH := Fatura.qFaturaBaslik.FieldByName('Tarih').AsDateTime;

  Fatura.qFaturaDetay.First;
    while not Fatura.qFaturaDetay.Eof do
      begin

        NetsisFatKalem := NetsisFatura.kalemYeni(Fatura.qFaturaDetay.FieldByName('stok_kod').AsString);
        NetsisFatKalem.STra_GCMIK := Fatura.qFaturaDetay.FieldByName('miktar').AsFloat;
        NetsisFatKalem.STra_BF := Fatura.qFaturaDetay.FieldByName('b_fiyat').AsFloat;
        NetsisFatKalem.DEPO_KODU := 1;

        NetsisFatKalem.STra_SatIsk := Fatura.qFaturaDetay.FieldByName('isk_1').AsFloat;
        NetsisFatKalem.STra_SatIsk2 := Fatura.qFaturaDetay.FieldByName('isk_2').AsFloat;
        NetsisFatKalem.STra_SatIsk3 := Fatura.qFaturaDetay.FieldByName('isk_3').AsFloat;
        NetsisFatKalem.STra_SatIsk4 := Fatura.qFaturaDetay.FieldByName('isk_4').AsFloat;
        NetsisFatKalem.STra_SatIsk5 := Fatura.qFaturaDetay.FieldByName('isk_5').AsFloat;


        Fatura.qFaturaDetay.Next;
      end;


  //Kayýtlarý saklama
  NetsisFatura.kayitYeni;
  ShowMessage('kayýt tamamlandý.');

  NetsisFatKalem := nil;
  NetsisFatUst := nil;
  NetsisFatura := nil;
  Sirket := nil;
  Kernel := nil;
//  Kernel.FreeNetsisLibrary;
  Screen.Cursor := crDefault;

end;

Procedure NetsisStokEkle();
Var
  Kernel : IKernel;
