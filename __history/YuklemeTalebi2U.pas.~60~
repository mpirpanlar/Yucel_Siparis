function TfrmYuklemeTalebi2.YuklemeNoGetir:String;
var
  UretimNo : String;
  q1 : TUniQuery;
begin

  q1 := TUniQuery.Create(nil);
  q1.Connection := frmDM.conAsya;

  with q1 do
    begin
      Application.ProcessMessages;
      Close;
      SQL.Clear;
//      SQL.Add('Select dbo.NumaraSeriAl(''YUKLEMENO'',''YUK'') as YuklemeNo');
      SQL.Add(' Select dbo.NumaraSeriAl2(''YUKLEMENO'',''YUK'') as YuklemeNo ');
      Open;
      Application.ProcessMessages;
      UretimNo := FieldByName('YuklemeNo').AsString;

      Close;
      SQL.Clear;
      SQL.Add('Update NumaraSerileri Set SonrakiSayi = SonrakiSayi+1 Where Formati = ''YUK''');
      ExecSQL;
      Close;
      FreeAndNil(q1);

      Result := UretimNo;
    end;

end;

procedure TfrmYuklemeTalebi2.btnYuklemeEsitKalanClick(Sender: TObject);
begin
  with qSiparisTemp do
    begin
      First;
      while not eof do
        begin
          Edit;
            FieldByName('YUKLEME_MIKTAR').Value := FieldByName('MIKTAR1').Value;
          Post;
          next;
        end;
      First;
      Refresh;
    end;
end;

