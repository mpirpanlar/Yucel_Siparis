  Kul : String;
  SipMiktar, YuklemeMiktar : Real;
begin

  Kul := Tmp.xKullaniciAdi;

  // AYNI CARÝ SKONTROLÜ
  qSiparisTemp.Close;
  qSiparisTemp.SQL.Clear;
