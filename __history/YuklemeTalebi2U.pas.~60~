    qSiparisTemp.ParamByName('Kul').AsString :=  Tmp.xKullaniciAdi;
  qSiparisTemp.Open;


  mSiparis.DisableControls;

  B := mSiparis.GetBookmark;
    try
      mSiparis.Bookmark := UniDBGrid1.SelectedRows[I];

