  qSiparisTemp.SQL.Clear;
  qSiparisTemp.SQL.Add('SELECT * FROM SIPARIS_TEMP WHERE KULLANICI =:Kul AND INCKEYNO =:inc ');
    qSiparisTemp.ParamByName('Kul').AsString := Tmp.xKullaniciAdi;
    qSiparisTemp.ParamByName('inc').AsString := mSiparis.FieldByName('INCKEYNO').Value;
