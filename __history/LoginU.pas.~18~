procedure TfrmLogin.btnGirisClick(Sender: TObject);
  Var
    Qry, Qry2:Tuniquery;
    SqlSorgu:String;
begin

  Qry:=Tuniquery.Create(nil);
  Qry.Connection:=frmDM.conAsya;

  Qry2:=Tuniquery.Create(nil);
  Qry2.Connection:=frmDM.conAsya;

//  SqlSorgu:='SELECT KullaniciID, KullaniciAd, KullaniciSifre, KullaniciGrupID,KullaniciDepoID FROM kullanici '
  SqlSorgu:='Select KullaniciID,KullaniciAd,KullaniciSifre,KullaniciGrupID,KullaniciDepoID,Skin,NetsisSirketKodu,NetsisSubeKodu,NetsisDepoKodu, NetsisPlasiyerKodu FRom Kullanici '
  +' where KullaniciAd = '''+lcKullanici.Text+''' and KullaniciSifre = '''+edSifre.Text+''' ';
  xTabloAc(Qry, SqlSorgu);
  if Qry.RecordCount=0 then UniMainModule.saHata.Show('Kullanc ve ﾞifre Kontrol ediniz.')
   else begin
    xKullaniciId := Qry.FieldByName('KullaniciID').AsInteger;
    xKullaniciGrupID:=Qry.FieldByName('KullaniciGrupID').AsInteger;
    xParaBirimi :='TL';
    xSubeKodu := Qry.FieldByName('NetsisSubeKodu').AsInteger;
    xKullaniciDepo := Qry.FieldByName('NetsisDepoKodu').AsInteger;
    xNetsisSirketKodu := Qry.FieldByName('NetsisSirketKodu').AsString;
    xKullaniciAdi:=lcKullanici.Text;
    xNetsisPlasiyer := Qry.FieldByName('NetsisPlasiyerKodu').AsString;

      SqlSorgu:='Select KullaniciGrupID, KullaniciGrupAd, Admin FROM KULLANICIGRUP '
      +' where KullaniciGrupID = '''+IntToStr(xKullaniciGrupID)+'''  ';
      xTabloAc(Qry2, SqlSorgu);
        if Qry.RecordCount=0 then
          begin
            UniMainModule.saHata.Show('Kullanc grubu bulunamad. ﾝlem devam edemez...');
            Abort;
          end
          else begin
            xKullaniciAdmin := qry2.FieldByName('Admin').Value;
          end;



    frmDM.qParametre.Close;
    frmDM.qParametre.ParamByName('Sube').Value := xSubeKodu;
    frmDM.qParametre.Open;
    xNetsisKullanici := frmDM.qParametre.FieldByName('NETSIS_KULLANICI_KODU').AsString;
    xNetsisSifre := frmDM.qParametre.FieldByName('NETSIS_KULLANICI_SIFRE').AsString;
    frmDM.qParametre.Close;

    xUnidacBaglanNetsis;


    if ckHatirla.Checked then begin
      UniApplication.Cookies.SetCookie('_Kullanici', lcKullanici.Text, Date + 7.0);
      UniApplication.Cookies.SetCookie('_Sifre', edSifre.Text, Date + 7.0);
      UniApplication.Cookies.SetCookie('_Hatirla', '1', Date + 7.0)
    end
    else UniApplication.Cookies.SetCookie('_Hatirla', '0', Date + 7.0);
     ModalResult:=mrOK;
   end;
end;

procedure TfrmLogin.edSifreKeyPress(Sender: TObject; var Key: Char);
begin
  if Key = #13 then
    begin
      btnGiris.Click;
    end;
end;

procedure TfrmLogin.UniLoginFormShow(Sender: TObject);
var
  Hatirla:String;
begin
    xUnidacBaglanAsya;
    qKullanici.Open;
    //  Hatirla:=
  if UniApplication.Cookies.Values['_Hatirla']='1' then begin
    lcKullanici.Text:= UniApplication.Cookies.Values['_Kullanici'];
    edSifre.Text:= UniApplication.Cookies.Values['_Sifre'];
    ckHatirla.Checked:=true;
  end;
end;

initialization
  RegisterAppFormClass(TfrmLogin);

end.
