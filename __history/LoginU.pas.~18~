  uniGUIClasses, uniGUIRegClasses, uniGUIForm, uniCheckBox, uniButton,
  uniMultiItem, uniComboBox, uniDBComboBox, uniDBLookupComboBox, uniEdit,
  uniPanel, uniLabel, dxGDIPlusClasses, uniImage, uniGUIBaseClasses, Data.DB,
  MemDS, DBAccess, Uni;

type
