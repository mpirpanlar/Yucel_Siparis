    qKullanici: TUniQuery;
    UniContainerPanel1: TUniContainerPanel;
    UniImage1: TUniImage;
    UniPanel1: TUniPanel;
    UniPanel2: TUniPanel;
    lcKullanici: TUniDBLookupComboBox;
    edSifre: TUniEdit;
    btnGiris: TUniButton;
    ckHatirla: TUniCheckBox;
    UniPanel3: TUniPanel;
    UniImage2: TUniImage;
    dsKullanici: TUniDataSource;
    procedure UniLoginFormShow(Sender: TObject);
    procedure btnGirisClick(Sender: TObject);
    procedure edSifreKeyPress(Sender: TObject; var Key: Char);
  private
    { Private declarations }
  public
    { Public declarations }
