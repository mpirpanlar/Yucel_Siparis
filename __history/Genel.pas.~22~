Procedure xRaporGoster (RaporAdi,PDFDosyaAdi : String ; FrxRapor : TfrxReport; frxPDF:TfrxPDFExport);
  var
    Stream: TStream;
    Qry:Tuniquery;
    fn : String;
  Begin
    Qry:=Tuniquery.Create(nil);
    Qry.Connection:=frmDM.conAsya;
    Qry.Close;
    Qry.SQL.Clear;
    Qry.SQL.Text:='Select * from raporlar where RaporAdi=:RaporAd';
    Qry.ParamByName('RaporAd').AsString:=RaporAdi;
    Qry.Open;
    Stream := Qry.CreateBlobStream(Qry.FieldByName('RaporData'), bmRead);

//    fn:=FormatDateTime('ddmmyyhhmmss.zzz', Now()) +'.pdf';
    fn:=PDFDosyaAdi +'.pdf';;
    FrxRapor.PrintOptions.ShowDialog := False;
    FrxRapor.ShowProgress:=false;
    FrxRapor.EngineOptions.SilentMode:=True;
    FrxRapor.EngineOptions.EnableThreadSafe := True;
    FrxRapor.EngineOptions.DestroyForms := False;
    frxPDF.Background:=True;
    frxPDF.ShowProgress:=False;
    frxPDF.ShowDialog:=False;
    frxPDF.FileName := UniServerModule.LocalCachePath + fn;
    frxPDF.DefaultPath := '';
    FrxRapor.PreviewOptions.AllowEdit:=False;
    FrxRapor.LoadFromStream(Stream);
    FrxRapor.PrepareReport();
    FrxRapor.Export( frxPDF);
    frmPDFGoster.UniURLFrame1.URL :=UniServerModule.LocalCacheURL + fn;
    frmPDFGoster.ShowModal();
    Stream.Free;
    Qry.Free;
  End;

