procedure xFormShow(AFormType: TuniFormClass; YetkiForm:String; Tip:Integer;FisNo:String); //Tip : 0 Yeni Tip : 1 Mevcut Kart ve Fiž Tipi
var
    TabSheetNew: TUniTabSheet; I,Z: Integer;
    PanelTabSheetNew: TUniPanel;
    F : TUniForm;
    Qry,QryCaption:Tuniquery;
    Label Atla;
begin
  MainForm.ShowMask('Bekleyiniz..');
  UniSession.Synchronize();
  ///Yetki
    QryCaption:=Tuniquery.Create(nil);
    QryCaption.Connection:=frmDM.conAsya;

    Qry:=Tuniquery.Create(nil);
    Qry.Connection:=frmDM.conAsya;
    Qry.Close;
    Qry.SQL.Clear;
    Qry.SQL.Text:='Select Gor,Sil,Degistir,Kaydet from YETKI where KullaniciGrupID=:KullaniciGrupID and FormName=:FormAdi';
    Qry.ParamByName('KullaniciGrupID').AsInteger:=Tmp.xKullaniciGrupID;
    Qry.ParamByName('FormAdi').AsString:=YetkiForm;
    Qry.Open;
    if Qry.FieldByName('Gor').AsInteger =0 then begin
       UniMainModule.saYetki.Show;
       Qry.Free;
       MainForm.HideMask;
       Abort;
    end;


  MainForm.NavPage.Visible:= True;
  {Check if exists, active tab if exist and exit}
  for I := 0 to MainForm.NavPage.PageCount - 1 do
    if MainForm.NavPage.Pages[I].Name = YetkiForm  then
      begin
        MainForm.NavPage.ActivePageIndex := I;
        MainForm.NavPage.ActivePage.Close;
        Goto Atla;
        //        Exit;
      end;
       Atla:
        QryCaption.Close;
        QryCaption.SQL.Clear;
        QryCaption.SQL.Text:='Select FormName,FormCaption from FormName where FormName=:FormAdi';
        QryCaption.ParamByName('FormAdi').AsString:=YetkiForm;
        QryCaption.Open;
  //if not found, then create it...
//  TabSheetNew              := TUniTabSheet.Create(NavPage);
  TabSheetNew              := TUniTabSheet.Create(MainForm.NavPage);
  TabSheetNew.PageControl  := MainForm.NavPage;
  TabSheetNew.Caption      := QryCaption.FieldByName('FormCaption').AsString;
  TabSheetNew.Name         := YetkiForm;
  TabSheetNew.Closable     := True;
  TabSheetNew.OnClose      := MainForm.CheckTab;


  PanelTabSheetNew := TUniPanel.Create(MainForm);
  PanelTabSheetNew.Align := alClient;
  PanelTabSheetNew.Parent := TabSheetNew;
  PanelTabSheetNew.AlignmentControl := uniAlignmentClient;
  PanelTabSheetNew.Layout := 'fit';
  PanelTabSheetNew.LayoutConfig.Margin:='1 1 1 1';
  PanelTabSheetNew.BorderStyle:=ubsNone;
  F:=AFormType.Create(UniApplication);
  F.Parent := PanelTabSheetNew;
  F.Tag:=Tip;
  F.Hint:=FisNo;
  F.Show;

          //////Yetkiler   Düzenle ve Sil
          if Qry.FieldByName('Sil').AsInteger = 0 then begin
              for Z:= 0 to pred (TuniForm(F).componentcount) do begin
                if (TuniForm(F).components[Z] is TuniButton) then
                  if TuniButton(TuniForm(F).Components[Z]).Name='btnSil' then
                    TuniButton(TuniForm(F).Components[Z]).Visible:= false;
              end;
          end;
          if Qry.FieldByName('Degistir').AsInteger = 0 then begin
              for Z:= 0 to pred (TuniForm(F).componentcount) do begin
                if (TuniForm(F).components[Z] is TuniButton) then
                  if TuniButton(TuniForm(F).Components[Z]).Name='btnDuzenle' then
                    TuniButton(TuniForm(F).Components[Z]).Visible:= false;
              end;
          end;
          Qry.free;
          /////////////////

  MainForm.lblKullanici.Caption := tmp.xKullaniciAdi;
  MainForm.NavPage.ActivePageIndex := MainForm.NavPage.PageCount - 1;
  MainForm.HideMask;
end;
