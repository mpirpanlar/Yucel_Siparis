function xKayitSor(Sorgu : String) : Boolean;
var
Qry:Tuniquery;
begin
  Qry:=Tuniquery.Create(nil);
  Qry.Connection:=frmDM.conAsya;
  Qry.Close;
  Qry.UnPrepare;
  Qry.SQL.Clear;
  Qry.SQL.Text:=Sorgu;
  Qry.Prepare;
  Qry.Open;
  Result := Qry.RecordCount > 0;
  Qry.Free;
end;
