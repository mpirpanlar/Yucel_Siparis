procedure TfrmStokBul.edMiktarClick(Sender: TObject);
begin
  edMiktar.SelectAll;
end;

procedure TfrmStokBul.edMiktarKeyPress(Sender: TObject; var Key: Char);
begin
  if Key = #13 then
    begin
      btnSecileniKullan.SetFocus;
      btnSecileniKullan.Click;
    end;

end;

procedure TfrmStokBul.edStokKodKeyPress(Sender: TObject; var Key: Char);
begin
  if Key = #13 then
    begin
      btnStokListele.SetFocus;
      btnStokListele.Click;
    end;
end;

procedure TfrmStokBul.btnSecileniKullanClick(Sender: TObject);
var
  Ek1,Ek2 : String;
begin
  if edMiktar.Value = 0 then
    begin
      UniMainModule.saHata.Show('Miktar 0 olamaz...');
      Abort;
    end;

  if BirimCombo.Text = '' then
    begin
      UniMainModule.saHata.Show('Birim se蓾lmelidir...');
      Abort;
    end;

  if dovizCombo.Text = '' then
    begin
      UniMainModule.saHata.Show('D饘iz Tipi se蓾lmelidir...');
      Abort;
    end;

  if edEk1.Text = '' then Ek1 := 'BOS';
  if edEk2.Text = '' then Ek2 := 'BOS';

  if chkOzel1.Checked = True then
    begin
      frmSiparisDM.StokEkle(spStokListe.FieldByName('STOK_KODU').AsString, BirimCombo.Text, edMiktar.Value,dovizCombo.Text,1,0,Ek1,Ek2);
    end else
    begin
      frmSiparisDM.StokEkle(spStokListe.FieldByName('STOK_KODU').AsString, BirimCombo.Text, edMiktar.Value,dovizCombo.Text,0,0,Ek1,Ek2);
    end;


  if frmSiparisDM.qFisBaslik.State IN [dsEdit,dsInsert] then frmSiparisDM.qFisBaslik.Post;

  if frmSiparisDM.qFisDetay.State IN [dsEdit,dsInsert] then frmSiparisDM.qFisDetay.Post;
      frmSiparisDM.qFisDetay.ApplyUpdates;

  if frmSiparisDM.qEk.State IN [dsEdit,dsInsert] then frmSiparisDM.qEk.Post;
      frmSiparisDM.qEk.ApplyUpdates;

  Close;

end;

procedure TfrmStokBul.UniDBGrid2CellClick(Column: TUniDBGridColumn);
begin
  BirimCombo.Items.Clear;
  BirimCombo.Items.Add(spStokListe.FieldByName('OLCU_BR1').AsString);
  BirimCombo.Items.Add(spStokListe.FieldByName('OLCU_BR2').AsString);
  BirimCombo.Items.Add(spStokListe.FieldByName('OLCU_BR3').AsString);
  BirimCombo.ItemIndex := 0;
  dovizCombo.KeyValue := spStokListe.FieldByName('SAT_DOV_TIP').Value;
  chkOzel1.Checked := False;
end;

